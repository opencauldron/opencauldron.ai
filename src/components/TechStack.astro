---
const techStack = [
  { name: "Next.js", category: "Framework", logo: "/logos/nextjs.png" },
  { name: "Tailwind CSS v4", category: "Styling", logo: "/logos/tailwind.png" },
  { name: "Drizzle ORM", category: "Database", logo: "/logos/drizzle.png" },
  { name: "Neon Postgres", category: "Database", logo: "/logos/neon.png" },
  { name: "Cloudflare R2", category: "Storage", logo: "/logos/cloudflare.png" },
  { name: "NextAuth.js", category: "Auth", logo: "/logos/nextauth.png" },
];
---

<!-- Tech Stack -->
<section id="stack" class="relative z-10 mx-auto max-w-6xl px-4 sm:px-6 py-16 sm:py-24">
  <div class="rounded-2xl ring-1 ring-[var(--color-border)] bg-[var(--color-card)] p-10 sm:p-14">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6 mb-10">
      <div>
        <h2 class="font-heading text-2xl font-bold tracking-tight sm:text-3xl">Built on a modern stack</h2>
        <p class="mt-2 text-[var(--color-muted)]">Production-grade tools you already know and love.</p>
      </div>
      <a href="https://github.com/opencauldron/opencauldron" target="_blank" rel="noopener"
        class="inline-flex h-10 items-center gap-2 rounded-lg bg-[var(--color-primary)] px-5 text-sm font-medium text-[var(--color-primary-fg)] hover:opacity-90 transition-opacity self-start">
        Read the docs
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/></svg>
      </a>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
      {techStack.map((tech) => (
        <div class="flex items-center gap-3.5 rounded-xl bg-[var(--color-background)] p-4 ring-1 ring-[var(--color-border)]/50">
          <img src={tech.logo} alt={tech.name} width="28" height="28" class="rounded-md" />
          <div>
            <p class="text-sm font-semibold">{tech.name}</p>
            <p class="text-xs text-[var(--color-muted)] mt-0.5">{tech.category}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
