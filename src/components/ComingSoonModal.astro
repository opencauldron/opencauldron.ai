<!-- Coming Soon Modal -->
<div id="coming-soon-modal" class="fixed inset-0 z-[100] hidden items-center justify-center">
  <div id="coming-soon-backdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>
  <div class="relative w-full max-w-sm mx-4 rounded-2xl ring-1 ring-[var(--color-border)] bg-[var(--color-card)] p-8 shadow-2xl text-center">
    <button id="coming-soon-close" class="absolute top-4 right-4 text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors cursor-pointer">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
    </button>
    <div id="coming-soon-icon" class="flex h-12 w-12 items-center justify-center rounded-full bg-[oklch(0.55_0.15_260)]/10 mx-auto mb-4">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="oklch(0.55 0.15 260)"><path d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286z"/></svg>
    </div>
    <h3 class="font-heading text-xl font-bold mb-2"><span id="coming-soon-feature"></span></h3>
    <p class="text-sm text-[var(--color-muted)] mb-5" id="coming-soon-desc">Coming soon. Follow us on <a href="https://github.com/opencauldron/opencauldron" target="_blank" rel="noopener" class="text-[var(--color-primary)] hover:underline">GitHub</a> for updates.</p>

    <!-- Email capture form (shown for Discord) -->
    <form id="discord-notify-form" name="discord-notify" method="POST" data-netlify="true" netlify-honeypot="bot-field" class="hidden">
      <input type="hidden" name="form-name" value="discord-notify" />
      <p class="hidden"><label>Don't fill this out: <input name="bot-field" /></label></p>
      <div class="flex gap-2">
        <input type="email" name="email" required placeholder="you@example.com"
          class="flex-1 rounded-lg bg-[var(--color-background)] px-4 py-2.5 text-sm ring-1 ring-[var(--color-border)] focus:ring-[var(--color-primary)] focus:outline-none transition-all placeholder:text-[var(--color-muted)]/50" />
        <button type="submit"
          class="shrink-0 inline-flex h-10 items-center justify-center rounded-lg px-4 text-sm font-semibold text-white transition-all hover:shadow-lg hover:shadow-[var(--color-primary)]/20 active:translate-y-px cursor-pointer"
          style="background: linear-gradient(135deg, oklch(0.58 0.22 280), oklch(0.65 0.20 300));">
          Notify me
        </button>
      </div>
    </form>

    <!-- Success message -->
    <div id="discord-notify-success" class="hidden">
      <div class="flex h-10 w-10 items-center justify-center rounded-full bg-[var(--color-teal)]/10 mx-auto mb-3">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-teal)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
      </div>
      <p class="text-sm font-medium">We'll let you know when it's live!</p>
    </div>
  </div>
</div>

<script>
  // Coming soon modal
  const csModal = document.getElementById('coming-soon-modal');
  const csFeature = document.getElementById('coming-soon-feature');
  const csDesc = document.getElementById('coming-soon-desc');
  const csClose = document.getElementById('coming-soon-close');
  const csBackdrop = document.getElementById('coming-soon-backdrop');
  const discordForm = document.getElementById('discord-notify-form') as HTMLFormElement;
  const discordSuccess = document.getElementById('discord-notify-success');

  function openComingSoon(name: string) {
    // Reset state
    discordForm?.classList.add('hidden');
    discordSuccess?.classList.add('hidden');
    if (csDesc) csDesc.classList.remove('hidden');

    if (name === 'Discord') {
      if (csFeature) csFeature.textContent = 'Discord is coming soon';
      if (csDesc) {
        csDesc.classList.remove('hidden');
        csDesc.textContent = 'Get notified when our Discord community launches.';
      }
      discordForm?.classList.remove('hidden');
    } else {
      if (csFeature) csFeature.textContent = name + ' is coming soon';
      if (csDesc) {
        csDesc.innerHTML = 'Coming soon. Follow us on <a href="https://github.com/opencauldron/opencauldron" target="_blank" rel="noopener" class="text-[var(--color-primary)] hover:underline">GitHub</a> for updates.';
      }
    }

    csModal?.classList.remove('hidden');
    csModal?.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function closeComingSoon() {
    csModal?.classList.add('hidden');
    csModal?.classList.remove('flex');
    document.body.style.overflow = '';
  }

  document.querySelectorAll('[data-coming-soon]').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const name = (btn as HTMLElement).dataset.comingSoon || '';
      openComingSoon(name);
    });
  });

  csClose?.addEventListener('click', closeComingSoon);
  csBackdrop?.addEventListener('click', closeComingSoon);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeComingSoon();
  });

  // Discord email form submission
  discordForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(discordForm);
    try {
      await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(data as any).toString(),
      });
      discordForm.classList.add('hidden');
      if (csDesc) csDesc.classList.add('hidden');
      discordSuccess?.classList.remove('hidden');
      setTimeout(closeComingSoon, 2500);
    } catch {
      discordForm.submit();
    }
  });
</script>
