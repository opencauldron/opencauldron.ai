---
import { GITHUB_NEW_PROVIDER_ISSUE } from "../config";

const imageProviders = [
  { name: "Recraft", logo: "/logos/recraft.png", models: ["V3", "20B", "V4", "V4 Pro"] },
  { name: "Ideogram", logo: "/logos/ideogram.png", models: ["3"] },
  { name: "Flux", logo: "/logos/bfl.png", models: ["1.1 Pro", "Dev", "Kontext", "Klein"] },
  { name: "Grok", logo: "/logos/xai.png", models: ["Imagine", "Pro"] },
  { name: "OpenAI", logo: "/logos/openai.png", models: ["2.0", "1.5", "1.0", "Mini"] },
  { name: "Gemini", logo: "/logos/gemini.png", models: ["Imagen 4", "Flash", "Lite", "Ultra", "Fast"] },
  { name: "Stability AI", logo: "/logos/stability.png", models: ["SDXL"] },
];

const videoProviders = [
  { name: "Wan", logo: "/logos/wan.png", models: ["2.6"] },
  { name: "Seedance", logo: "/logos/seedance.png", models: ["1.5 Pro"] },
  { name: "Hailuo", logo: "/logos/minimax.png", models: ["Hailuo"] },
  { name: "Kling", logo: "/logos/kling.png", models: ["2.6"] },
  { name: "Runway", logo: "/logos/runway.png", models: ["Gen-3 Alpha"] },
  { name: "Veo", logo: "/logos/google-veo.png", models: ["3"] },
];
---

<!-- Providers -->
<section id="providers" class="relative z-10 mx-auto max-w-6xl px-4 sm:px-6 py-16 sm:py-24">
  <div class="text-center mb-16">
    <h2 class="font-heading text-3xl font-bold tracking-tight sm:text-4xl">
      Powered by the
      <span style="background: linear-gradient(135deg, oklch(0.76 0.13 280), oklch(0.65 0.20 300)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">best AI models</span>
    </h2>
    <p class="mt-4 text-[var(--color-muted)] max-w-xl mx-auto text-balance">
      One interface, many engines. Choose the right model for each job.
    </p>
  </div>

  <!-- Mobile: single combined card with segmented tab switcher -->
  <div
    id="providers-mobile"
    data-tab="image"
    class="sm:hidden rounded-2xl ring-1 ring-[var(--color-border)] bg-[var(--color-card)] p-5"
  >
    <!-- Segmented control -->
    <div
      role="tablist"
      aria-label="Model categories"
      class="grid grid-cols-2 gap-1 rounded-xl bg-[var(--color-background)] p-1 ring-1 ring-[var(--color-border)]/60"
    >
      <button
        type="button"
        role="tab"
        id="providers-tab-image"
        aria-controls="providers-panel-image"
        aria-selected="true"
        data-target="image"
        class="providers-tab group flex items-center justify-center gap-2 rounded-lg h-10 text-sm font-semibold text-[var(--color-muted)] transition-colors aria-selected:bg-[var(--color-card)] aria-selected:text-[var(--color-foreground)] aria-selected:ring-1 aria-selected:ring-[var(--color-border)]"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
        <span>Image</span>
        <span class="ml-0.5 inline-flex h-5 min-w-5 items-center justify-center rounded-full bg-[var(--color-primary)]/10 px-1.5 text-[10px] font-semibold text-[var(--color-primary)]">{imageProviders.length}</span>
      </button>
      <button
        type="button"
        role="tab"
        id="providers-tab-video"
        aria-controls="providers-panel-video"
        aria-selected="false"
        data-target="video"
        class="providers-tab group flex items-center justify-center gap-2 rounded-lg h-10 text-sm font-semibold text-[var(--color-muted)] transition-colors aria-selected:bg-[var(--color-card)] aria-selected:text-[var(--color-foreground)] aria-selected:ring-1 aria-selected:ring-[var(--color-border)]"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m16 13 5.223 3.482a.5.5 0 0 0 .777-.416V7.87a.5.5 0 0 0-.752-.432L16 10.5"/><rect x="2" y="6" width="14" height="12" rx="2"/></svg>
        <span>Video</span>
        <span class="ml-0.5 inline-flex h-5 min-w-5 items-center justify-center rounded-full bg-[var(--color-violet)]/10 px-1.5 text-[10px] font-semibold text-[var(--color-violet)]">{videoProviders.length}</span>
      </button>
    </div>

    <!-- Image panel -->
    <div
      id="providers-panel-image"
      role="tabpanel"
      aria-labelledby="providers-tab-image"
      class="providers-panel mt-4 grid gap-2.5"
    >
      {imageProviders.map((p) => (
        <div class="flex items-center gap-3 rounded-xl bg-[var(--color-background)] p-3 ring-1 ring-[var(--color-border)]/50">
          <img src={p.logo} alt={p.name} width="32" height="32" class="rounded-lg shrink-0" />
          <div class="min-w-0 flex-1">
            <p class="text-sm font-semibold">{p.name}</p>
            {p.models.length > 0 && (
              <div class="flex flex-wrap gap-1.5 mt-1">
                {p.models.map((m) => (
                  <span class="rounded-full bg-[var(--color-primary)]/10 px-2 py-0.5 text-[10px] font-medium text-[var(--color-primary)]">{m}</span>
                ))}
              </div>
            )}
          </div>
        </div>
      ))}
    </div>

    <!-- Video panel (hidden by default) -->
    <div
      id="providers-panel-video"
      role="tabpanel"
      aria-labelledby="providers-tab-video"
      hidden
      class="providers-panel mt-4 grid gap-2.5"
    >
      {videoProviders.map((p) => (
        <div class="flex items-center gap-3 rounded-xl bg-[var(--color-background)] p-3 ring-1 ring-[var(--color-border)]/50">
          <img src={p.logo} alt={p.name} width="32" height="32" class="rounded-lg shrink-0" />
          <div class="min-w-0 flex-1">
            <p class="text-sm font-semibold">{p.name}</p>
            {p.models.length > 0 && (
              <div class="flex flex-wrap gap-1.5 mt-1">
                {p.models.map((m) => (
                  <span class="rounded-full bg-[var(--color-violet)]/10 px-2 py-0.5 text-[10px] font-medium text-[var(--color-violet)]">{m}</span>
                ))}
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Desktop / tablet: original two-card grid (unchanged) -->
  <div class="hidden sm:grid gap-8 sm:grid-cols-2">
    <!-- Image models -->
    <div class="rounded-2xl ring-1 ring-[var(--color-border)] bg-[var(--color-card)] p-8">
      <div class="flex items-center gap-2.5 mb-6">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
        <h3 class="font-heading text-lg font-semibold">Image Models</h3>
      </div>
      <div class="grid gap-3">
        {imageProviders.map((p) => (
          <div class="flex items-center gap-4 rounded-xl bg-[var(--color-background)] p-3 ring-1 ring-[var(--color-border)]/50">
            <img src={p.logo} alt={p.name} width="32" height="32" class="rounded-lg" />
            <div class="min-w-0">
              <p class="text-sm font-semibold">{p.name}</p>
              {p.models.length > 0 && (
                <div class="flex flex-wrap gap-1.5 mt-1">
                  {p.models.map((m) => (
                    <span class="rounded-full bg-[var(--color-primary)]/10 px-2 py-0.5 text-[10px] font-medium text-[var(--color-primary)]">{m}</span>
                  ))}
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Video models -->
    <div class="rounded-2xl ring-1 ring-[var(--color-border)] bg-[var(--color-card)] p-8">
      <div class="flex items-center gap-2.5 mb-6">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m16 13 5.223 3.482a.5.5 0 0 0 .777-.416V7.87a.5.5 0 0 0-.752-.432L16 10.5"/><rect x="2" y="6" width="14" height="12" rx="2"/></svg>
        <h3 class="font-heading text-lg font-semibold">Video Models</h3>
      </div>
      <div class="grid gap-3">
        {videoProviders.map((p) => (
          <div class="flex items-center gap-4 rounded-xl bg-[var(--color-background)] p-3 ring-1 ring-[var(--color-border)]/50">
            <img src={p.logo} alt={p.name} width="32" height="32" class="rounded-lg" />
            <div class="min-w-0">
              <p class="text-sm font-semibold">{p.name}</p>
              {p.models.length > 0 && (
                <div class="flex flex-wrap gap-1.5 mt-1">
                  {p.models.map((m) => (
                    <span class="rounded-full bg-[var(--color-violet)]/10 px-2 py-0.5 text-[10px] font-medium text-[var(--color-violet)]">{m}</span>
                  ))}
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Request a provider CTA -->
  <div class="mt-8 text-center">
    <a
      href={GITHUB_NEW_PROVIDER_ISSUE}
      target="_blank"
      rel="noopener"
      class="inline-flex items-center gap-2 text-sm font-medium text-[var(--color-primary)] hover:text-[var(--color-foreground)] transition-colors"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v8"/><path d="M8 12h8"/></svg>
      Request a provider
    </a>
  </div>
</section>

<script>
  const root = document.getElementById("providers-mobile");
  if (root) {
    const tabs = root.querySelectorAll<HTMLButtonElement>(".providers-tab");
    const panels = {
      image: root.querySelector<HTMLElement>("#providers-panel-image"),
      video: root.querySelector<HTMLElement>("#providers-panel-video"),
    };

    const setActive = (target: "image" | "video") => {
      root.dataset.tab = target;
      tabs.forEach((t) => {
        const isActive = t.dataset.target === target;
        t.setAttribute("aria-selected", String(isActive));
        t.tabIndex = isActive ? 0 : -1;
      });
      (Object.keys(panels) as Array<keyof typeof panels>).forEach((key) => {
        const panel = panels[key];
        if (!panel) return;
        if (key === target) {
          panel.removeAttribute("hidden");
        } else {
          panel.setAttribute("hidden", "");
        }
      });
    };

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const target = tab.dataset.target as "image" | "video" | undefined;
        if (target) setActive(target);
      });
      tab.addEventListener("keydown", (e) => {
        if (e.key !== "ArrowLeft" && e.key !== "ArrowRight") return;
        e.preventDefault();
        const order: Array<"image" | "video"> = ["image", "video"];
        const current = (root.dataset.tab as "image" | "video") || "image";
        const idx = order.indexOf(current);
        const next = e.key === "ArrowRight" ? order[(idx + 1) % order.length] : order[(idx - 1 + order.length) % order.length];
        setActive(next);
        root.querySelector<HTMLButtonElement>(`.providers-tab[data-target="${next}"]`)?.focus();
      });
    });
  }
</script>
