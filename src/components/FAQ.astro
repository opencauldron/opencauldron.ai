---
import { GITHUB_LICENSE, GITHUB_DISCUSSIONS, DISCORD_INVITE, DOCS_INTRO } from "../config";

type Scope = "self-host" | "cloud" | "both";
type Accent = "sky" | "primary" | "fuchsia" | "violet" | "teal";

const faqs: {
  q: string;
  a: string;
  topic: string;
  scope: Scope;
  accent: Accent;
  icon: string;
}[] = [
  {
    q: "Is OpenCauldron really free?",
    topic: "Pricing",
    scope: "both",
    accent: "sky",
    icon: `<circle cx="8" cy="8" r="6"/><path d="M18.09 10.37A6 6 0 1 1 10.34 18"/><path d="M7 6h1v4"/><path d="m16.71 13.88.7.71-2.82 2.82"/>`,
    a: `Depends on how you run it. <strong>Self-host</strong> is free and source-available under the Sustainable Use License — you only pay providers like Google or Replicate directly for AI model API usage with your own keys. <strong>Cloud</strong> is free during invite-only beta; paid tiers will come later, and you can always bring your own provider keys to keep costs predictable.`,
  },
  {
    q: "What API keys do I need?",
    topic: "Setup",
    scope: "both",
    accent: "primary",
    icon: `<path d="m21 2-9.6 9.6"/><circle cx="7.5" cy="15.5" r="5.5"/><path d="m15.5 7.5 3 3L22 7l-3-3"/>`,
    a: `You only need keys for the providers you want to use. For example, a Google AI API key gives you access to Imagen 4 and Veo. A Replicate token unlocks Flux Pro. You can start with just one provider and add more as needed.`,
  },
  {
    q: "Can I add custom models?",
    topic: "Custom models",
    scope: "self-host",
    accent: "fuchsia",
    icon: `<path d="M19.439 7.85c-.049.322.059.648.289.878l1.568 1.568c.47.47.706 1.087.706 1.704s-.235 1.233-.706 1.704l-1.611 1.611a.98.98 0 0 1-.837.276c-.47-.07-.802-.48-.968-.925a2.501 2.501 0 1 0-3.214 3.214c.446.166.855.497.925.968a.979.979 0 0 1-.276.837l-1.61 1.61a2.404 2.404 0 0 1-1.705.707 2.402 2.402 0 0 1-1.704-.706l-1.568-1.568a1.026 1.026 0 0 0-.877-.29c-.493.074-.84.504-1.02.968a2.5 2.5 0 1 1-3.237-3.237c.464-.18.894-.527.967-1.02a1.026 1.026 0 0 0-.289-.877l-1.568-1.568A2.402 2.402 0 0 1 1.998 12c0-.617.236-1.234.706-1.704L4.23 8.77c.24-.24.581-.353.917-.303.515.077.877.528 1.073 1.01a2.5 2.5 0 1 0 3.259-3.259c-.482-.196-.933-.558-1.01-1.073-.05-.336.062-.676.303-.917l1.525-1.525A2.402 2.402 0 0 1 12 1.998c.617 0 1.234.236 1.704.706l1.568 1.568c.23.23.556.338.877.29.493-.074.84-.504 1.02-.968a2.5 2.5 0 1 1 3.237 3.237c-.464.18-.894.527-.967 1.02Z"/>`,
    a: `Yes. OpenCauldron has a provider registry that makes it straightforward to add new models. You can fork the repo and add any model that has an API. We also welcome PRs to add new providers to the main project.`,
  },
  {
    q: "How is billing handled?",
    topic: "Billing",
    scope: "both",
    accent: "violet",
    icon: `<path d="M4 2v20l2-1 2 1 2-1 2 1 2-1 2 1 2-1 2 1V2l-2 1-2-1-2 1-2-1-2 1-2-1-2 1Z"/><path d="M16 8h-6a2 2 0 1 0 0 4h4a2 2 0 1 1 0 4H8"/><path d="M12 17.5v-11"/>`,
    a: `On <strong>self-host</strong>, OpenCauldron doesn't handle billing — your API keys are charged directly by each provider at their standard rates. On <strong>Cloud</strong>, you'll see provider costs the same way plus a monthly subscription for the hosted convenience (free during beta). Either way, the built-in usage dashboard breaks down every generation's cost by user, model, and brand.`,
  },
  {
    q: "Where is my data stored?",
    topic: "Privacy",
    scope: "both",
    accent: "teal",
    icon: `<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/>`,
    a: `On <strong>self-host</strong>, everything stays on your infrastructure — prompts and metadata in your PostgreSQL database, generated assets in your Cloudflare R2 bucket (or any S3-compatible storage). The self-hosted build never phones home or collects telemetry. On <strong>Cloud</strong>, your data lives in our managed PostgreSQL and R2 with per-workspace isolation — same code as self-host, just running for you.`,
  },
  {
    q: "Can I use it without self-hosting?",
    topic: "Hosting",
    scope: "cloud",
    accent: "sky",
    icon: `<path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"/>`,
    a: `Yes — <strong>OpenCauldron Cloud</strong> is the hosted version of the studio. Sign in with Google, get a workspace, start generating — no Docker, no setup. It's in invite-only beta right now; request a spot from the Cloud toggle at the top of the page. Prefer to run your own? Docker takes a few minutes — see the installation docs.`,
  },
  {
    q: "What license is OpenCauldron under?",
    topic: "License",
    scope: "both",
    accent: "primary",
    icon: `<path d="m16 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"/><path d="m2 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"/><path d="M7 21h10"/><path d="M12 3v18"/><path d="M3 7h2c2 0 5-1 7-2 2 1 5 2 7 2h2"/>`,
    a: `OpenCauldron is released under the <a href="${GITHUB_LICENSE}" target="_blank" rel="noopener" class="text-[var(--color-primary)] hover:underline">Sustainable Use License</a> — the same license n8n uses. It's source-available: free for any internal business, personal, or non-commercial use, free to fork, modify, and contribute back. The one thing it prevents is third parties selling it as a competing commercial service. This keeps the project sustainable while staying open to almost everyone who wants to use or improve it.`,
  },
];

const accentVar: Record<Accent, string> = {
  sky: "var(--color-sky)",
  primary: "var(--color-primary)",
  fuchsia: "var(--color-fuchsia)",
  violet: "var(--color-violet)",
  teal: "var(--color-teal)",
};

const scopeStyles: Record<Scope, { label: string; cls: string }> = {
  "self-host": {
    label: "Self-host",
    cls: "bg-[var(--color-teal)]/10 text-[var(--color-teal)] ring-[var(--color-teal)]/20",
  },
  cloud: {
    label: "Cloud",
    cls: "bg-[var(--color-sky)]/10 text-[var(--color-sky)] ring-[var(--color-sky)]/20",
  },
  both: {
    label: "Both",
    cls: "bg-[var(--color-fuchsia)]/10 text-[var(--color-fuchsia)] ring-[var(--color-fuchsia)]/20",
  },
};

const delays = ["delay-100", "delay-200", "delay-300", "delay-400", "delay-500", "delay-600", "delay-700"];
---

<!-- FAQ -->
<section class="relative z-10 mx-auto max-w-4xl px-4 sm:px-6 py-16 sm:py-24">
  <div class="text-center mb-16">
    <h2 class="font-heading text-3xl font-bold tracking-tight sm:text-4xl">
      Frequently asked
      <span style="background: linear-gradient(135deg, oklch(0.76 0.13 280), oklch(0.65 0.20 300)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">questions</span>
    </h2>
  </div>

  <div class="space-y-2" id="faq-list">
    {faqs.map((item, i) => {
      const accent = accentVar[item.accent];
      const scope = scopeStyles[item.scope];
      const delay = delays[i] ?? "delay-700";
      return (
        <details
          class:list={["faq-item group rounded-xl ring-1 ring-[var(--color-border)] bg-[var(--color-card)] transition-all animate-fade-up", delay]}
          style={`--faq-accent: ${accent};`}
        >
          <summary class="grid grid-cols-[40px_1fr_auto] sm:grid-cols-[44px_1fr_auto_auto] items-center gap-3 sm:gap-4 cursor-pointer p-5 sm:p-6 [&::-webkit-details-marker]:hidden">
            <div
              class="flex h-10 w-10 sm:h-11 sm:w-11 items-center justify-center rounded-lg transition-colors"
              style={`background: color-mix(in oklch, ${accent} 14%, transparent);`}
            >
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke={accent} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={item.icon} />
            </div>
            <div class="min-w-0">
              <p class="text-[10px] font-semibold uppercase tracking-[0.08em]" style={`color: ${accent};`}>{item.topic}</p>
              <h3 class="font-heading text-base sm:text-lg font-semibold tracking-tight text-[var(--color-foreground)] mt-0.5">{item.q}</h3>
            </div>
            <span class:list={["hidden sm:inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-semibold ring-1", scope.cls]}>
              {scope.label}
            </span>
            <svg class="faq-chevron h-4 w-4 text-[var(--color-muted)] group-hover:text-[var(--color-foreground)] group-open:rotate-180 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="m6 9 6 6 6-6" />
            </svg>
          </summary>
          <div class="px-5 sm:px-6 pb-6 pl-[60px] sm:pl-[76px] text-sm leading-relaxed text-[var(--color-muted)]" set:html={item.a} />
        </details>
      );
    })}
  </div>

  <!-- Closing CTA: Still have questions? -->
  <div class="mt-8 rounded-xl ring-1 ring-[var(--color-fuchsia)]/20 bg-gradient-to-br from-[var(--color-fuchsia)]/[0.06] to-[var(--color-violet)]/[0.06] p-6 sm:p-7">
    <div class="flex flex-col sm:flex-row sm:items-center gap-5">
      <div class="flex h-10 w-10 sm:h-11 sm:w-11 shrink-0 items-center justify-center rounded-lg" style="background: color-mix(in oklch, var(--color-fuchsia) 14%, transparent);">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-fuchsia)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
          <path d="M9.5 9h.01"/><path d="M14.5 9h.01"/>
        </svg>
      </div>
      <div class="flex-1 min-w-0">
        <p class="font-heading text-base font-semibold text-[var(--color-foreground)]">Still have questions?</p>
        <p class="text-sm text-[var(--color-muted)] mt-0.5">Browse the docs, ask in Discord, or open a GitHub discussion &mdash; the team and community are around.</p>
      </div>
      <div class="flex flex-col xs:flex-row sm:flex-row flex-wrap gap-2.5 shrink-0">
        <a
          href={DOCS_INTRO}
          class="inline-flex h-10 items-center justify-center gap-2 rounded-lg px-4 text-sm font-medium text-[var(--color-foreground)] ring-1 ring-[var(--color-border)] hover:ring-[var(--color-fuchsia)]/40 hover:bg-[var(--color-card)] transition-all"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>
          Docs
        </a>
        <a
          href={DISCORD_INVITE}
          target="_blank"
          rel="noopener"
          class="inline-flex h-10 items-center justify-center gap-2 rounded-lg px-4 text-sm font-medium text-[var(--color-foreground)] ring-1 ring-[var(--color-border)] hover:ring-[var(--color-fuchsia)]/40 hover:bg-[var(--color-card)] transition-all"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
          Discord
        </a>
        <a
          href={GITHUB_DISCUSSIONS}
          target="_blank"
          rel="noopener"
          class="inline-flex h-10 items-center justify-center gap-2 rounded-lg px-4 text-sm font-medium text-[var(--color-foreground)] ring-1 ring-[var(--color-border)] hover:ring-[var(--color-fuchsia)]/40 hover:bg-[var(--color-card)] transition-all"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          Discussions
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .faq-item:hover {
    border-color: transparent;
    box-shadow: inset 0 0 0 1px color-mix(in oklch, var(--faq-accent) 30%, transparent);
  }
  .faq-item[open] {
    background: linear-gradient(180deg, color-mix(in oklch, var(--faq-accent) 5%, var(--color-card)) 0%, var(--color-card) 60%);
    box-shadow: inset 0 0 0 1px color-mix(in oklch, var(--faq-accent) 35%, transparent);
  }
</style>
