---
// Wand-sparkles SVG path (per design system) shared across logo + hero card.
const WAND = `
<path d="m21.64 3.64-1.28-1.28a1.21 1.21 0 0 0-1.72 0L2.36 18.64a1.21 1.21 0 0 0 0 1.72l1.28 1.28a1.2 1.2 0 0 0 1.72 0L21.64 5.36a1.2 1.2 0 0 0 0-1.72"/>
<path d="m14 7 3 3"/><path d="M5 6v4"/><path d="M19 14v4"/><path d="M10 2v2"/><path d="M7 8H3"/><path d="M21 16h-4"/><path d="M11 3H9"/>
`;

// Sidebar navigation, mirrors the actual product.
const navItems = [
  { label: "Home", icon: "home", active: true },
  { label: "Activity", icon: "activity", active: false },
  { label: "Gallery", icon: "gallery", active: false },
  { label: "Review", icon: "review", active: false },
];

const libraryItems = [
  { label: "Assets", icon: "assets" },
  { label: "Collections", icon: "collections" },
  { label: "Brews", icon: "brews" },
  { label: "Workflows", icon: "workflows" },
  { label: "LoRAs", icon: "loras" },
];

const promptChips = [
  "Neon cyberpunk alley",
  "Golden-hour cabin",
  "Product hero",
  "Slow-mo portrait",
];

const onboardingCards = [
  {
    title: "Create a brand",
    desc: "Spin up a brand to organize assets and set its colors, voice, and references.",
    icon: "palette",
    highlight: false,
  },
  {
    title: "Invite a teammate",
    desc: "Per-people brighter seats you invite, so they can start working immediately.",
    icon: "user-plus",
    highlight: false,
  },
  {
    title: "Try the chat agent",
    desc: "Ask anything about your studio — drafts, review queue, brand activity, stats.",
    icon: "chat",
    highlight: true, // gets soft glow from callout 3
  },
  {
    title: "Set up your profile",
    desc: "Add an avatar and display name so your work has a face on it.",
    icon: "avatar",
    highlight: false,
  },
];

// Tiny helper: returns an inline SVG string for a named icon.
// Lucide-style, 24x24 viewBox, stroke-1.75 (between feature 1.5 and UI 2).
function iconFor(name: string, size: number = 14): string {
  const s = size;
  const open = `<svg width="${s}" height="${s}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">`;
  const close = `</svg>`;
  switch (name) {
    case "home":
      return open + `<path d="M3 9.5 12 3l9 6.5V20a1 1 0 0 1-1 1h-5v-7h-6v7H4a1 1 0 0 1-1-1V9.5Z"/>` + close;
    case "activity":
      return open + `<path d="M22 12h-4l-3 9L9 3l-3 9H2"/>` + close;
    case "gallery":
      return open + `<rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.1-3.1a2 2 0 0 0-2.8 0L6 21"/>` + close;
    case "review":
      return open + `<path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>` + close;
    case "assets":
      return open + `<rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>` + close;
    case "collections":
      return open + `<path d="M4 4h6a2 2 0 0 1 2 2v14"/><path d="M22 6a2 2 0 0 0-2-2h-6"/><path d="M2 8h20"/><path d="M2 12h20"/><path d="M2 16h20"/><path d="M2 20h20"/>` + close;
    case "brews":
      return open + `<path d="M5 19s-2-1-2-7 7-9 9-9c2 0 9 3 9 9s-2 7-2 7"/><path d="M5 19l4-4"/><path d="M19 19l-4-4"/>` + close;
    case "workflows":
      return open + `<rect x="3" y="3" width="6" height="6" rx="1"/><rect x="15" y="15" width="6" height="6" rx="1"/><path d="M21 7h-4a2 2 0 0 0-2 2v6"/><path d="M3 17h4a2 2 0 0 0 2-2V9"/>` + close;
    case "loras":
      return open + `<circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.6 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.6a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9c.36.15.68.4.94.74"/>` + close;
    case "palette":
      return open + `<circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"/>` + close;
    case "user-plus":
      return open + `<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/>` + close;
    case "chat":
      return open + `<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>` + close;
    case "avatar":
      return open + `<path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>` + close;
    default:
      return open + `<circle cx="12" cy="12" r="4"/>` + close;
  }
}
---

<!-- App Showcase: a faithful, legible mockup of Studio Home with 3 floating callouts -->
<section
  id="app-showcase"
  class="relative z-10 mx-auto max-w-6xl px-4 sm:px-6 py-16 sm:py-24 lg:py-28"
>
  <!-- Section header -->
  <div class="text-center mb-12 sm:mb-14">
    <div class="inline-flex items-center gap-2 rounded-full bg-[var(--color-fuchsia)]/10 px-4 py-1.5 text-xs font-semibold text-[var(--color-fuchsia)] ring-1 ring-[var(--color-fuchsia)]/20 mb-6">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={WAND} />
      Inside the studio
    </div>
    <h2 class="font-heading text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">
      Studio, chat, and every model —
      <span style="background: linear-gradient(135deg, oklch(0.76 0.13 280), oklch(0.68 0.20 325)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">one workspace.</span>
    </h2>
    <p class="mt-4 text-[var(--color-muted)] max-w-2xl mx-auto text-balance leading-relaxed">
      Brand teams, marketers, creators, and agencies generating together. Here's what's actually inside.
    </p>
  </div>

  <!-- ============================================== -->
  <!-- DESKTOP MOCKUP (sm+): Studio Home + 3 callouts -->
  <!-- ============================================== -->
  <div class="showcase-stage hidden sm:block relative" data-showcase-stage>
    <!-- The mockup itself: pure-CSS render of Studio Home -->
    <div class="showcase-mockup relative mx-auto rounded-2xl ring-1 ring-[var(--color-border)] bg-[var(--color-card)] overflow-hidden shadow-2xl shadow-[var(--color-primary)]/10">
      <!-- Inner studio layout: sidebar + main -->
      <div class="flex h-full text-[13px] leading-snug text-[var(--color-foreground)]">

        <!-- =================== SIDEBAR =================== -->
        <aside class="showcase-sidebar relative flex flex-col gap-3 border-r border-[var(--color-border)] bg-[var(--color-background)]/50 px-3 py-4">
          <!-- Brand row -->
          <div class="flex items-center gap-2 px-2 pb-2">
            <div class="flex h-7 w-7 items-center justify-center rounded-lg shrink-0" style="background: linear-gradient(135deg, oklch(0.58 0.22 280), oklch(0.65 0.20 300));">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={WAND} />
            </div>
            <span class="font-heading text-[13px] font-semibold tracking-tight">OpenCauldron</span>
          </div>

          <!-- Studio | Chat toggle (callout 3 anchor) -->
          <div
            data-callout-anchor="3"
            class="showcase-tabtoggle relative flex items-center gap-1 rounded-lg bg-[var(--color-card)] p-0.5 ring-1 ring-[var(--color-border)]"
          >
            <button class="flex-1 rounded-md bg-[var(--color-background)] px-2.5 py-1.5 text-[12px] font-semibold text-[var(--color-foreground)] ring-1 ring-[var(--color-border)]">
              Studio
            </button>
            <button class="flex-1 rounded-md px-2.5 py-1.5 text-[12px] font-medium text-[var(--color-muted)]">
              Chat
            </button>
          </div>

          <!-- Search -->
          <div class="flex items-center gap-2 rounded-lg bg-[var(--color-card)] px-2.5 py-1.5 ring-1 ring-[var(--color-border)]">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="var(--color-muted)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            <span class="text-[12px] text-[var(--color-muted)]">Search...</span>
            <span class="ml-auto rounded bg-[var(--color-background)] px-1.5 py-0.5 text-[10px] font-mono text-[var(--color-muted)] ring-1 ring-[var(--color-border)]">⌘K</span>
          </div>

          <!-- + Create button -->
          <button
            type="button"
            class="animate-shimmer relative flex items-center justify-center gap-1.5 rounded-lg px-3 py-2 text-[12.5px] font-semibold text-white"
            style="background: linear-gradient(135deg, oklch(0.58 0.22 280), oklch(0.65 0.20 300), oklch(0.68 0.19 280), oklch(0.60 0.22 260)); background-size: 300% 300%;"
          >
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
            Create
          </button>

          <!-- Primary nav -->
          <nav class="flex flex-col gap-0.5 mt-1">
            {navItems.map((item) => (
              <a
                href="#"
                class:list={[
                  "flex items-center gap-2.5 rounded-md px-2.5 py-1.5 text-[12.5px] transition-colors",
                  item.active
                    ? "bg-[var(--color-card)] text-[var(--color-foreground)] ring-1 ring-[var(--color-border)]"
                    : "text-[var(--color-muted)] hover:text-[var(--color-foreground)]",
                ]}
              >
                <span class="flex h-4 w-4 items-center justify-center" set:html={iconFor(item.icon)} />
                {item.label}
              </a>
            ))}
          </nav>

          <!-- BRANDS section (callout 1 anchor) -->
          <div data-callout-anchor="1" class="showcase-brands relative mt-3">
            <div class="flex items-center justify-between px-2 mb-1.5">
              <span class="text-[10px] font-semibold uppercase tracking-wider text-[var(--color-muted)]">Brands</span>
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="var(--color-muted)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
            </div>
            <div class="flex flex-col gap-0.5">
              <a href="#" class="flex items-center gap-2.5 rounded-md px-2.5 py-1.5 text-[12.5px] text-[var(--color-muted)] hover:text-[var(--color-foreground)]">
                <span class="h-2 w-2 rounded-full bg-[var(--color-muted)]/40"></span>
                Personal
              </a>
              <a href="#" class="flex items-center gap-2.5 rounded-md px-2.5 py-1.5 text-[12.5px] text-[var(--color-muted)] hover:text-[var(--color-foreground)]">
                <span class="h-2 w-2 rounded-full" style="background: var(--color-fuchsia);"></span>
                Halcyon
              </a>
              <a href="#" class="flex items-center gap-2.5 rounded-md px-2.5 py-1.5 text-[12.5px] text-[var(--color-muted)] hover:text-[var(--color-foreground)]">
                <span class="h-2 w-2 rounded-full" style="background: var(--color-teal);"></span>
                Northwind
              </a>
              <a href="#" class="flex items-center gap-2.5 rounded-md px-2.5 py-1.5 text-[12.5px] text-[var(--color-muted)] hover:text-[var(--color-foreground)]">
                <span class="h-2 w-2 rounded-full" style="background: var(--color-sky);"></span>
                Mercer &amp; Field
              </a>
              <a href="#" class="flex items-center gap-2 rounded-md px-2.5 py-1.5 text-[12px] text-[var(--color-muted)]/80">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
                Add brand
              </a>
            </div>
          </div>

          <!-- LIBRARY section -->
          <div class="mt-3">
            <div class="px-2 mb-1.5">
              <span class="text-[10px] font-semibold uppercase tracking-wider text-[var(--color-muted)]">Library</span>
            </div>
            <div class="flex flex-col gap-0.5">
              {libraryItems.map((item) => (
                <a href="#" class="flex items-center gap-2.5 rounded-md px-2.5 py-1.5 text-[12.5px] text-[var(--color-muted)] hover:text-[var(--color-foreground)]">
                  <span class="flex h-4 w-4 items-center justify-center" set:html={iconFor(item.icon)} />
                  {item.label}
                </a>
              ))}
            </div>
          </div>

          <!-- DISCOVER section (truncated) -->
          <div class="mt-3 px-2">
            <span class="text-[10px] font-semibold uppercase tracking-wider text-[var(--color-muted)]">Discover</span>
          </div>

          <!-- Footer: user -->
          <div class="mt-auto flex items-center gap-2 rounded-lg p-2 ring-1 ring-[var(--color-border)] bg-[var(--color-card)]">
            <div class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-[11px] font-semibold text-white" style="background: linear-gradient(135deg, oklch(0.58 0.22 280), oklch(0.65 0.20 300));">
              A
            </div>
            <div class="min-w-0 flex-1 leading-tight">
              <p class="truncate text-[11.5px] font-semibold">Adam Levoy</p>
              <p class="text-[10px] text-[var(--color-muted)]">Personal studio</p>
            </div>
          </div>
        </aside>

        <!-- =================== MAIN CANVAS =================== -->
        <main class="showcase-canvas relative flex-1 overflow-hidden">
          <!-- Header bar -->
          <div class="flex items-center justify-between border-b border-[var(--color-border)] px-6 py-3">
            <div class="flex items-center gap-3 text-[12px] text-[var(--color-muted)]">
              <span>Studio</span>
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
              <span class="text-[var(--color-foreground)]">Home</span>
            </div>
            <div class="flex items-center gap-2 text-[var(--color-muted)]">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>
            </div>
          </div>

          <!-- Inner content area -->
          <div class="px-8 py-7">
            <!-- Welcome -->
            <h3 class="font-heading text-[26px] font-bold tracking-tight">
              Welcome to your studio, Adam.
            </h3>
            <p class="mt-1.5 text-[13px] text-[var(--color-muted)] max-w-md leading-relaxed">
              Your studio is set up and empty. Make your first piece and the rest of the app — drafts, the review queue, your weekly stats — starts filling in around you.
            </p>

            <!-- Hero card: Generate your first piece (callout 2 anchor) -->
            <div
              data-callout-anchor="2"
              class="showcase-hero relative mt-6 overflow-hidden rounded-xl p-5 animate-shimmer"
              style="background: linear-gradient(135deg, oklch(0.58 0.22 280), oklch(0.65 0.20 300), oklch(0.68 0.19 280), oklch(0.60 0.22 260)); background-size: 300% 300%;"
            >
              <div class="flex items-start justify-between gap-6">
                <div>
                  <p class="font-heading text-[18px] font-bold text-white">
                    Generate your first piece
                  </p>
                  <p class="mt-1 text-[12.5px] text-white/85 leading-relaxed max-w-sm">
                    Describe what you want to see — text, image, or video.
                  </p>
                </div>
                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-white/15 ring-1 ring-white/25 backdrop-blur-sm">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" set:html={WAND} />
                </div>
              </div>
            </div>

            <!-- Or start from a prompt -->
            <div class="mt-5 mb-2">
              <span class="text-[10px] font-semibold uppercase tracking-wider text-[var(--color-muted)]">Or start from a prompt</span>
            </div>
            <div class="flex flex-wrap gap-2">
              {promptChips.map((chip) => (
                <button class="rounded-full px-3 py-1.5 text-[11.5px] text-[var(--color-muted)] ring-1 ring-[var(--color-border)] bg-[var(--color-card)] hover:text-[var(--color-foreground)] hover:ring-[var(--color-primary)]/40 transition-colors">
                  {chip}
                </button>
              ))}
            </div>

            <!-- Onboarding 2x2 grid -->
            <div class="mt-6 grid grid-cols-2 gap-3">
              {onboardingCards.map((card) => (
                <div
                  data-card-highlight={card.highlight ? "3" : undefined}
                  class:list={[
                    "showcase-onb-card relative rounded-xl bg-[var(--color-card)] p-4 ring-1 ring-[var(--color-border)] transition-all",
                    card.highlight && "showcase-highlight-target",
                  ]}
                >
                  <div class="flex items-center gap-2.5 mb-1.5">
                    <span class="flex h-7 w-7 items-center justify-center rounded-lg bg-[var(--color-primary)]/10 ring-1 ring-[var(--color-primary)]/20 text-[var(--color-primary)]" set:html={iconFor(card.icon, 14)} />
                    <p class="font-heading text-[13.5px] font-semibold">{card.title}</p>
                  </div>
                  <p class="text-[11.5px] text-[var(--color-muted)] leading-relaxed">
                    {card.desc}
                  </p>
                </div>
              ))}
            </div>
          </div>
        </main>
      </div>
    </div>

    <!-- ===================== FLOATING CALLOUTS ===================== -->
    <!-- 3 callouts cycle in sequence with SVG connectors -->
    <div class="callout-layer pointer-events-none absolute inset-0">

      <!-- Connector SVGs (one per callout, color-matched). Drawn in % space. -->
      <svg class="absolute inset-0 h-full w-full" preserveAspectRatio="none" viewBox="0 0 100 100" aria-hidden="true">
        <!-- Callout 1: sky → BRANDS. Callout sits over canvas, line goes left to sidebar. -->
        <path class="callout-line callout-line-1" d="M 22 28 C 20 36, 18 48, 16 56" />
        <!-- Callout 2: primary → hero card (top-right). From callout bottom-left toward hero. -->
        <path class="callout-line callout-line-2" d="M 78 18 C 70 24, 62 30, 52 36" />
        <!-- Callout 3: fuchsia → chat tab (sidebar top) AND chat-agent card (mid-bottom-left). -->
        <path class="callout-line callout-line-3" d="M 78 66 C 60 52, 35 30, 14 12" />
        <path class="callout-line callout-line-3" d="M 78 70 C 60 74, 45 76, 35 78" />
      </svg>

      <!-- Callout 1: BRANDS / sky -->
      <div class="callout callout-1" style="--callout-color: var(--color-sky);">
        <div class="callout-inner">
          <p class="callout-title">Brands × creators in one workspace</p>
          <p class="callout-sub">Brand presets, shared assets, approval workflows — every generation stays on-brief.</p>
        </div>
      </div>

      <!-- Callout 2: every model / primary -->
      <div class="callout callout-2" style="--callout-color: var(--color-primary);">
        <div class="callout-inner">
          <p class="callout-title">Every major model, one prompt box</p>
          <p class="callout-sub">Imagen, Flux, Ideogram, Recraft, Runway, Luma, Veo, MiniMax — no tab-juggling.</p>
        </div>
      </div>

      <!-- Callout 3: chat agent / fuchsia -->
      <div class="callout callout-3" style="--callout-color: var(--color-fuchsia);">
        <div class="callout-inner">
          <p class="callout-title">Or just ask. The chat agent knows your studio.</p>
          <p class="callout-sub">Drafts, review queue, brand activity, stats — ask anything in natural language.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- ============================================= -->
  <!-- MOBILE (<sm): simplified mockup + inline notes -->
  <!-- ============================================= -->
  <div class="sm:hidden">
    <!-- Mobile mockup: collapsed sidebar + single-column main -->
    <div class="mx-auto max-w-sm overflow-hidden rounded-2xl ring-1 ring-[var(--color-border)] bg-[var(--color-card)] shadow-2xl shadow-[var(--color-primary)]/10">
      <div class="flex text-[12px]">
        <!-- Icon-only sidebar -->
        <aside class="flex w-12 flex-col items-center gap-3 border-r border-[var(--color-border)] bg-[var(--color-background)]/50 py-3">
          <!-- Brand -->
          <div class="flex h-7 w-7 items-center justify-center rounded-lg" style="background: linear-gradient(135deg, oklch(0.58 0.22 280), oklch(0.65 0.20 300));">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={WAND} />
          </div>
          <!-- Studio/Chat toggle (stacked dots) -->
          <div class="flex flex-col items-center gap-1 rounded-md bg-[var(--color-card)] p-1 ring-1 ring-[var(--color-border)]">
