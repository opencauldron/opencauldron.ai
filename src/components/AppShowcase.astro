                      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
                      Download
                    </button>
                    <button class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-[var(--color-card)] text-[9px] ring-1 ring-[var(--color-border)]/50">
                      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.582a.5.5 0 0 1 0 .963L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/></svg>
                      Animate
                    </button>
                  </div>
                </div>

              </div>

            </div>

          <!-- Right: Canvas with blurred preview + image reveal -->
          <div class="hidden sm:flex w-1/2 border-l border-[var(--color-border)] items-center justify-center relative overflow-hidden">
            <!-- Blurred silhouette (visible during steps 0-3) -->
            <div class="absolute inset-0 flex items-center justify-center" data-cauldron-blur>
              <img src="/screenshots/cauldron-result.webp" alt="" class="w-[85%] h-[85%] object-cover rounded-xl" style="filter: blur(30px) saturate(0.4) brightness(0.3); opacity: 0.5;" />
            </div>
            <!-- Revealed image (step 4) — diffusion-style blur reveal -->
            <div class="absolute inset-0 opacity-0" data-result-reveal>
              <img src="/screenshots/cauldron-result.webp" alt="Generated cauldron image" class="w-full h-full object-cover" data-result-img style="filter: blur(40px) saturate(0) brightness(1.5);" />
            </div>
          </div>
        </div>


        <!-- Shimmer overlay -->
        <div class="showcase-shimmer" data-shimmer aria-hidden="true"></div>
      </div>
    </div>
  </div>

  <!-- Step description (desktop only — mobile has its own caption) -->
  <div class="hidden md:block mt-8 text-center" data-showcase-caption>
    <p class="text-base sm:text-lg font-medium" data-caption-text>Write a detailed prompt describing exactly what you want to create.</p>
  </div>
</section>

<!-- GSAP showcase animations -->
<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener('DOMContentLoaded', () => {
    const section = document.getElementById('app-showcase');
    const header = document.querySelector('[data-showcase-header]');
    const browser = document.querySelector('[data-showcase-browser]');
    const shimmer = document.querySelector('[data-shimmer]');
    const caption = document.querySelector('[data-showcase-caption]');
    const cauldronBlur = document.querySelector('[data-cauldron-blur]') as HTMLElement;
    const resultReveal = document.querySelector('[data-result-reveal]') as HTMLElement;

    if (section && browser) {
      gsap.set(header, { opacity: 0, y: 24 });
      gsap.set(browser, { opacity: 0, y: 60, rotateX: 8, transformOrigin: 'center bottom' });
      gsap.set(caption, { opacity: 0, y: 12 });

      const revealTl = gsap.timeline({ paused: true });

      revealTl
        .to(header, { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out' })
        .to(browser, { opacity: 1, y: 0, rotateX: 0, duration: 1, ease: 'power3.out' }, '-=0.3')
        .to(shimmer, { x: '200%', duration: 0.8, ease: 'power2.inOut' }, '-=0.4')
        .to(caption, { opacity: 1, y: 0, duration: 0.5, ease: 'power2.out' }, '-=0.4')
        .add(() => { startWalkthrough(); });

      ScrollTrigger.create({
        trigger: section,
        start: 'top 75%',
        once: true,
        onEnter: () => revealTl.play()
      });
    }

    // === Walkthrough logic ===
    const walkSteps = document.querySelectorAll('.walk-step');
    const walkTabEls = document.querySelectorAll('[data-walk-tab]');
    const typingTarget = document.querySelector('[data-typing-target]') as HTMLElement;
    const typingCursor = document.querySelector('[data-typing-cursor]') as HTMLElement;
    const charCount = document.querySelector('[data-char-count]') as HTMLElement;

    let walkCurrent = 0;
    let walkTimer: ReturnType<typeof setInterval> | null = null;
    let walkAnimating = false;
    let typingInterval: ReturnType<typeof setInterval> | null = null;
    let walkthroughStarted = false;
    const WALK_INTERVAL = 4500;

    const walkCaptions = [
      'Write a detailed prompt describing exactly what you want to create.',
      'Choose from 5+ AI models — each with different strengths and pricing.',
      'Use templates or AI rewrite to enhance your prompt automatically.',
      'Fine-tune aspect ratio, resolution, format, and advanced settings.',
      'Hit generate and watch your creation come to life.',
    ];

    function startTyping() {
      if (!typingTarget) return;
      const fullText = typingTarget.textContent || '';
      typingTarget.textContent = '';
      if (charCount) charCount.textContent = '0';
      if (typingCursor) typingCursor.style.display = 'inline-block';
      let i = 0;
      typingInterval = setInterval(() => {
        if (i < fullText.length) {
          typingTarget.textContent = fullText.slice(0, i + 1);
          if (charCount) charCount.textContent = String(i + 1);
          i++;
        } else {
          if (typingInterval) clearInterval(typingInterval);
          typingInterval = null;
        }
      }, 18);
    }

    function stopTyping() {
      if (typingInterval) {
        clearInterval(typingInterval);
        typingInterval = null;
      }
    }

    function goToStep(idx: number) {
      if (walkAnimating || idx === walkCurrent) return;
      if (idx < 0 || idx >= walkSteps.length) return;
      walkAnimating = true;
      stopTyping();

      const currentStep = walkSteps[walkCurrent] as HTMLElement;
      const nextStep = walkSteps[idx] as HTMLElement;
      const captionText = document.querySelector('[data-caption-text]');

      // Animate out
      gsap.to(currentStep, {
        opacity: 0,
        x: idx > walkCurrent ? -20 : 20,
        duration: 0.25,
        ease: 'power2.in',
        onComplete: () => {
          currentStep.classList.remove('active');
          gsap.set(currentStep, { x: 0 });

          // Animate in
          gsap.set(nextStep, { opacity: 0, x: idx > walkCurrent ? 20 : -20 });
          nextStep.classList.add('active');
          gsap.to(nextStep, {
            opacity: 1,
            x: 0,
            duration: 0.35,
            ease: 'power2.out',
            onComplete: () => {
              walkAnimating = false;
              // Start typing on step 0
              if (idx === 0) startTyping();
              // Diffusion-style reveal in right panel on step 4
              if (idx === 4) {
                const img = document.querySelector('[data-result-img]') as HTMLElement;
                if (cauldronBlur) gsap.to(cauldronBlur, { opacity: 0, duration: 0.3 });
                if (resultReveal) {
                  const diffusionTl = gsap.timeline();
                  diffusionTl
                    .set(resultReveal, { opacity: 1 })
                    .set(img, { filter: 'blur(40px) saturate(0) brightness(1.5)' })
                    .to(img, { filter: 'blur(20px) saturate(0.3) brightness(1.3)', duration: 0.4, ease: 'none' })
                    .to(img, { filter: 'blur(8px) saturate(0.6) brightness(1.1)', duration: 0.5, ease: 'none' })
                    .to(img, { filter: 'blur(2px) saturate(0.9) brightness(1.02)', duration: 0.4, ease: 'none' })
                    .to(img, { filter: 'blur(0px) saturate(1) brightness(1)', duration: 0.3, ease: 'power2.out' });
                }
              } else {
                // Reset when leaving step 4
                if (walkCurrent === 4) {
                  if (cauldronBlur) gsap.to(cauldronBlur, { opacity: 1, duration: 0.3 });
                  if (resultReveal) gsap.set(resultReveal, { opacity: 0 });
                }
              }
              walkCurrent = idx;
            }
          });
        }
      });

      // Update tabs
      walkTabEls.forEach((t, i) => {
        t.classList.toggle('active', i === idx);
      });
      const activeTab = walkTabEls[idx] as HTMLElement;
      if (activeTab) positionIndicator(activeTab);

      // Update caption
      if (captionText) {
        gsap.to(captionText, {
          opacity: 0,
          duration: 0.15,
          onComplete: () => {
            captionText.textContent = walkCaptions[idx];
            gsap.to(captionText, { opacity: 1, duration: 0.2 });
          }
        });
      }
    }

    function nextWalkStep() {
      const next = (walkCurrent + 1) % walkSteps.length;
      goToStep(next);
    }

    function startWalkthrough() {
      if (walkthroughStarted) return;
      walkthroughStarted = true;
      if (resultReveal) gsap.set(resultReveal, { opacity: 0 });
      startTyping();
      // Update caption to step 0
      const captionText = document.querySelector('[data-caption-text]');
      if (captionText) captionText.textContent = walkCaptions[0];
      walkTimer = setInterval(nextWalkStep, WALK_INTERVAL);
    }

    function pauseWalkTimer() {
      if (walkTimer) { clearInterval(walkTimer); walkTimer = null; }
    }

    function resetWalkTimer() {
      pauseWalkTimer();
      walkTimer = setInterval(nextWalkStep, WALK_INTERVAL);
    }

    // Step tabs (replacing old screen tabs + walk dots)
    const walkTabs = document.querySelectorAll('[data-walk-tab]');
    const indicator = document.querySelector('[data-tab-indicator]') as HTMLElement;
    const viewport = document.getElementById('showcase-viewport');

    function positionIndicator(tab: HTMLElement) {
      if (!indicator) return;
      gsap.to(indicator, { x: tab.offsetLeft, width: tab.offsetWidth, duration: 0.3, ease: 'power2.inOut' });
    }

    const firstTab = document.querySelector('[data-walk-tab].active') as HTMLElement;
    if (firstTab && indicator) {
      gsap.set(indicator, { x: firstTab.offsetLeft, width: firstTab.offsetWidth });
    }

    walkTabs.forEach((tab, i) => {
      tab.addEventListener('click', () => {
        goToStep(i);
        resetWalkTimer();
      });
      // Pause on hover over tab
      tab.addEventListener('mouseenter', pauseWalkTimer);
      tab.addEventListener('mouseleave', resetWalkTimer);
    });

    // Pause on hover over content area
    if (viewport) {
      viewport.addEventListener('mouseenter', pauseWalkTimer);
      viewport.addEventListener('mouseleave', resetWalkTimer);
    }

    window.addEventListener('resize', () => {
      const activeTab = document.querySelector('[data-walk-tab].active') as HTMLElement;
      if (activeTab) positionIndicator(activeTab);
    });
  });
</script>

<style>
  /* Mobile phone frame — sells "real native app screenshot" */
  .phone-frame {
    width: 100%;
    max-width: 340px;
    padding: 8px;
    border-radius: 44px;
    background: linear-gradient(165deg, oklch(0.20 0.02 280), oklch(0.10 0.02 280));
    box-shadow:
      0 0 0 1.5px oklch(0.30 0.02 280),
      inset 0 0 0 1px oklch(0.08 0.02 280),
      0 30px 60px -15px oklch(0.08 0.04 280 / 0.8),
      0 0 80px oklch(0.68 0.19 280 / 0.08);
  }
  .phone-screen {
    border-radius: 36px;
    overflow: hidden;
    position: relative;
  }
  /* Subtle inner highlight on the bezel for realism */
  .phone-frame::before {
    content: '';
    pointer-events: none;
  }
</style>
