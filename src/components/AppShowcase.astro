          <!-- Right: Canvas with blurred preview + image reveal -->
          <div class="hidden sm:flex w-1/2 border-l border-[var(--color-border)] items-center justify-center relative overflow-hidden">
            <!-- Blurred silhouette (visible during steps 0-3) -->
            <div class="absolute inset-0 flex items-center justify-center" data-cauldron-blur>
              <img src="/screenshots/cauldron-result.webp" alt="" class="w-[85%] h-[85%] object-cover rounded-xl" style="filter: blur(30px) saturate(0.4) brightness(0.3); opacity: 0.5;" />
            </div>
            <!-- Revealed image (step 4) — diffusion-style blur reveal -->
            <div class="absolute inset-0 opacity-0" data-result-reveal>
              <img src="/screenshots/cauldron-result.webp" alt="Generated cauldron image" class="w-full h-full object-cover" data-result-img style="filter: blur(40px) saturate(0) brightness(1.5);" />
