<style>
  /* --------------------------------------------------------------- */
  /* DESKTOP MOCKUP SIZING                                           */
  /* --------------------------------------------------------------- */
  /* Fixed aspect ratio keeps inner type at consistent native px size.
     Inner text is sized in absolute px so it stays legible regardless
     of viewport (no `text-[8px]` survivors). */
  .showcase-mockup {
    width: 100%;
    aspect-ratio: 16 / 10;
    max-height: 720px;
  }
  .showcase-sidebar {
    width: 200px;
    flex-shrink: 0;
  }
  @media (min-width: 1024px) {
    .showcase-sidebar { width: 220px; }
  }

  /* --------------------------------------------------------------- */
  /* CALLOUT BOXES                                                    */
  /* --------------------------------------------------------------- */
  .callout {
    position: absolute;
    width: 260px;
    pointer-events: auto;
    opacity: 0;
    transform: translateY(8px);
    will-change: opacity, transform;
  }
  .callout-inner {
    border-radius: 0.75rem;
    background: color-mix(in oklab, var(--color-background) 88%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: 0.875rem 1rem;
    box-shadow:
      0 0 0 1px color-mix(in oklab, var(--callout-color) 35%, transparent),
      0 12px 30px -10px color-mix(in oklab, var(--callout-color) 40%, transparent),
      0 0 40px color-mix(in oklab, var(--callout-color) 18%, transparent);
  }
  .callout-title {
    font-family: var(--font-heading);
    font-size: 13px;
    font-weight: 700;
    color: var(--callout-color);
    line-height: 1.3;
    margin: 0;
  }
  .callout-sub {
    margin-top: 4px;
    font-size: 11.5px;
    color: var(--color-foreground);
    opacity: 0.78;
    line-height: 1.45;
  }

  /* Positions — percentages relative to .showcase-stage. Callouts sit
     over the canvas (not the sidebar) so they never occlude what they're
     pointing at. Connectors reach across to the highlighted surface. */
  .callout-1 { top: 18%; left: 22%;   }  /* over canvas top-left, points left to BRANDS */
  .callout-2 { top: 4%;  right: -8px; }  /* top-right, points down-left to gradient hero */
  .callout-3 { top: 62%; right: -8px; }  /* below hero, points up to chat tab + chat-agent card */

  @media (min-width: 1280px) {
    .callout-2 { right: -16px; }
    .callout-3 { right: -16px; }
  }

  /* On narrower tablet widths the canvas is tighter; nudge callout 1 down
     so it doesn't overlap the welcome heading. */
  @media (max-width: 1023px) {
    .callout-1 { top: 22%; left: 30%; }
    .callout { width: 220px; }
  }

  /* --------------------------------------------------------------- */
  /* CONNECTOR LINES                                                  */
  /* --------------------------------------------------------------- */
  .callout-line {
    fill: none;
    stroke-width: 0.3;
    stroke-linecap: round;
    stroke-dasharray: 1 1.2;
    vector-effect: non-scaling-stroke;
    opacity: 0;
  }
  .callout-line-1 { stroke: var(--color-sky);     filter: drop-shadow(0 0 4px color-mix(in oklab, var(--color-sky)     50%, transparent)); }
  .callout-line-2 { stroke: var(--color-primary); filter: drop-shadow(0 0 4px color-mix(in oklab, var(--color-primary) 50%, transparent)); }
  .callout-line-3 { stroke: var(--color-fuchsia); filter: drop-shadow(0 0 4px color-mix(in oklab, var(--color-fuchsia) 50%, transparent)); }

  /* --------------------------------------------------------------- */
  /* ANCHOR HIGHLIGHTS                                                */
  /* --------------------------------------------------------------- */
  [data-callout-anchor],
  [data-card-highlight] {
    border-radius: 0.5rem;
  }
  .showcase-onb-card.showcase-highlight-target {
    border-radius: 0.75rem;
  }

  /* --------------------------------------------------------------- */
  /* LOOP ANIMATION (12s cycle, pure CSS)                             */
  /* --------------------------------------------------------------- */
  /* Timeline: each callout shows for ~3s, then fades; ~1.5s rest at end.
       0.8s - 4.0s  : callout 1
       4.0s - 7.2s  : callout 2
       7.2s - 10.5s : callout 3
       10.5s - 12s  : rest
     In % of 12s:  callout1 7-33  |  callout2 33-60  |  callout3 60-87 */
  @keyframes callout-cycle-1 {
    0%, 5%, 35%, 100% { opacity: 0; transform: translateY(8px); }
    10%, 30%          { opacity: 1; transform: translateY(0); }
  }
  @keyframes callout-cycle-2 {
    0%, 30%, 62%, 100% { opacity: 0; transform: translateY(8px); }
    35%, 57%           { opacity: 1; transform: translateY(0); }
  }
  @keyframes callout-cycle-3 {
    0%, 57%, 90%, 100% { opacity: 0; transform: translateY(8px); }
    62%, 85%           { opacity: 1; transform: translateY(0); }
  }

  @keyframes line-cycle-1 {
    0%, 5%, 35%, 100% { opacity: 0; }
    10%, 30%          { opacity: 0.85; }
  }
  @keyframes line-cycle-2 {
    0%, 30%, 62%, 100% { opacity: 0; }
    35%, 57%           { opacity: 0.85; }
  }
  @keyframes line-cycle-3 {
    0%, 57%, 90%, 100% { opacity: 0; }
    62%, 85%           { opacity: 0.85; }
  }

  /* Anchor glow rings cycle in sync with their callout. Using outline +
     box-shadow so they don't disturb layout. */
  @keyframes anchor-glow-1 {
    0%, 5%, 35%, 100% { box-shadow: 0 0 0 0 transparent; }
    10%, 30%          {
      box-shadow:
        0 0 0 2px color-mix(in oklab, var(--color-sky) 55%, transparent),
        0 0 24px color-mix(in oklab, var(--color-sky) 35%, transparent);
    }
  }
  @keyframes anchor-glow-2 {
    0%, 30%, 62%, 100% { box-shadow: 0 0 0 0 transparent; }
    35%, 57%           {
      box-shadow:
        0 0 0 2px color-mix(in oklab, var(--color-primary) 60%, transparent),
        0 0 30px color-mix(in oklab, var(--color-primary) 40%, transparent);
    }
  }
  @keyframes anchor-glow-3 {
    0%, 57%, 90%, 100% { box-shadow: 0 0 0 0 transparent; }
    62%, 85%           {
      box-shadow:
        0 0 0 2px color-mix(in oklab, var(--color-fuchsia) 60%, transparent),
        0 0 30px color-mix(in oklab, var(--color-fuchsia) 35%, transparent);
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .callout-1 { animation: callout-cycle-1 12s ease-in-out infinite; }
    .callout-2 { animation: callout-cycle-2 12s ease-in-out infinite; }
    .callout-3 { animation: callout-cycle-3 12s ease-in-out infinite; }
    .callout-line-1 { animation: line-cycle-1 12s ease-in-out infinite; }
    .callout-line-2 { animation: line-cycle-2 12s ease-in-out infinite; }
    .callout-line-3 { animation: line-cycle-3 12s ease-in-out infinite; }
    [data-callout-anchor="1"] { animation: anchor-glow-1 12s ease-in-out infinite; }
    [data-callout-anchor="2"] { animation: anchor-glow-2 12s ease-in-out infinite; }
    [data-callout-anchor="3"] { animation: anchor-glow-3 12s ease-in-out infinite; }
    [data-card-highlight="3"] { animation: anchor-glow-3 12s ease-in-out infinite; }

    /* Hover pauses the loop so users can read. */
    .showcase-stage:hover .callout,
    .showcase-stage:hover .callout-line,
    .showcase-stage:hover [data-callout-anchor],
    .showcase-stage:hover [data-card-highlight] {
      animation-play-state: paused;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    /* All callouts visible at full opacity. No looping. No shimmer. */
    .callout { opacity: 1; transform: none; }
    .callout-line { opacity: 0.7; }
    [data-callout-anchor="1"] {
      box-shadow: 0 0 0 2px color-mix(in oklab, var(--color-sky) 50%, transparent);
    }
    [data-callout-anchor="2"] {
      box-shadow: 0 0 0 2px color-mix(in oklab, var(--color-primary) 55%, transparent);
    }
    [data-callout-anchor="3"],
    [data-card-highlight="3"] {
      box-shadow: 0 0 0 2px color-mix(in oklab, var(--color-fuchsia) 55%, transparent);
    }
    .animate-shimmer { animation: none !important; }
  }
</style>
