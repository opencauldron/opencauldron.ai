---
const cards = [
  {
    title: "We don't train on your work",
    body: 'Your prompts and generations stay yours. We don\'t train models on them or share them with third parties. <span class="text-[var(--color-muted)]/80">When you bring your own provider keys, that provider\'s policy applies on their side.</span>',
    accent: "sky",
    icon: `<rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>`,
  },
  {
    title: "Your keys, your spend",
    body: "Bring your own OpenAI, Replicate, or model-provider keys. Requests pass through &mdash; providers bill you, no markup, no key escrow.",
    accent: "primary",
    icon: `<circle cx="7.5" cy="15.5" r="5.5"/><path d="m21 2-9.6 9.6"/><path d="m15.5 7.5 3 3L22 7l-3-3"/>`,
  },
  {
    title: "Export and exit anytime",
    body: "Workspaces, prompts, and assets export to the same schema as self-host. Walk away with your data intact &mdash; no lock-in.",
    accent: "fuchsia",
    icon: `<path d="M9 11V6a3 3 0 0 1 6 0v5"/><path d="M12 11v9"/><path d="M5 11h14l-1.5 9.5A2 2 0 0 1 15.5 22h-7a2 2 0 0 1-2-1.5L5 11Z"/>`,
  },
  {
    title: "Same code, in the open",
    body: "Cloud runs the source-available studio. Audit it, fork it, or self-host the exact same build whenever you want.",
    accent: "violet",
    icon: `<path d="m21.64 3.64-1.28-1.28a1.21 1.21 0 0 0-1.72 0L2.36 18.64a1.21 1.21 0 0 0 0 1.72l1.28 1.28a1.2 1.2 0 0 0 1.72 0L21.64 5.36a1.2 1.2 0 0 0 0-1.72"/><path d="m14 7 3 3"/><path d="M5 6v4"/><path d="M19 14v4"/><path d="M10 2v2"/><path d="M7 8H3"/><path d="M21 16h-4"/><path d="M11 3H9"/>`,
  },
];

const accentVar: Record<string, string> = {
  primary: "var(--color-primary)",
  sky: "var(--color-sky)",
  fuchsia: "var(--color-fuchsia)",
  violet: "var(--color-violet)",
};
---

<!-- Data Privacy (Cloud only) -->
<section data-mode-section="hosted" class="relative z-10 mx-auto max-w-6xl px-4 sm:px-6 py-16 sm:py-24">
  <div class="rounded-2xl ring-1 ring-[var(--color-border)] bg-[var(--color-card)] p-10 sm:p-14">
    <div class="text-center mb-12">
      <h2 class="font-heading text-2xl font-bold tracking-tight sm:text-3xl">
        How we handle
        <span style="background: linear-gradient(135deg, oklch(0.76 0.13 280), oklch(0.65 0.20 300)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">your data</span>
      </h2>
      <p class="mt-3 text-[var(--color-muted)] max-w-xl mx-auto">
        Four commitments we can make today &mdash; verifiable in the source, not in a marketing PDF.
      </p>
    </div>

    <div class="grid gap-5 sm:grid-cols-2">
      {cards.map((card) => (
        <div class="rounded-xl bg-[var(--color-background)] p-6 ring-1 ring-[var(--color-border)]/60 transition-all duration-300 hover:ring-[var(--color-primary)]/30">
          <div
            class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg"
            style={`background: color-mix(in oklch, ${accentVar[card.accent]} 14%, transparent);`}
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke={accentVar[card.accent]} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={card.icon} />
          </div>
          <h3 class="font-heading text-base font-semibold mb-1.5">{card.title}</h3>
          <p class="text-sm leading-relaxed text-[var(--color-muted)]" set:html={card.body} />
        </div>
      ))}
    </div>
  </div>
</section>
