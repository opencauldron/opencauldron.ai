          </div>
          <div class="rounded-xl bg-[var(--color-primary)]/10 p-3 text-center ring-1 ring-[var(--color-primary)]/20">
            <div class="text-lg mb-1">🔥</div>
            <p class="text-[10px] font-semibold text-[var(--color-primary)]">Kindling</p>
            <p class="text-[9px] text-[var(--color-muted)] mt-0.5">+25 XP</p>
          </div>
          <div class="rounded-xl bg-[var(--color-primary)]/10 p-3 text-center ring-1 ring-[var(--color-primary)]/20">
            <div class="text-lg mb-1">🧭</div>
            <p class="text-[10px] font-semibold text-[var(--color-primary)]">Ranger</p>
            <p class="text-[9px] text-[var(--color-muted)] mt-0.5">+25 XP</p>
          </div>
          <div class="rounded-xl bg-[var(--color-primary)]/10 p-3 text-center ring-1 ring-[var(--color-primary)]/20">
            <div class="text-lg mb-1">🎬</div>
            <p class="text-[10px] font-semibold text-[var(--color-primary)]">Illusionist</p>
            <p class="text-[9px] text-[var(--color-muted)] mt-0.5">+20 XP</p>
          </div>
          <!-- Locked feat -->
