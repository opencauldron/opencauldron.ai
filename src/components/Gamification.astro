            <p class="text-xs text-[var(--color-muted)] mt-0.5">Hit milestones, build streaks, explore models — earn badges along the way.</p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-[var(--color-sky)]/10 mt-0.5">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-sky)" stroke-width="1.5"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5C7 4 9 7 12 7s5-3 7.5-3a2.5 2.5 0 0 1 0 5H18"/><path d="M18 15h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M6 15H4.5a2.5 2.5 0 0 1 0 5H6"/><path d="M18 21h1.5a2.5 2.5 0 0 0 0-5H18"/><line x1="6" x2="18" y1="9" y2="9"/><line x1="6" x2="18" y1="15" y2="15"/><line x1="6" x2="18" y1="21" y2="21"/></svg>
