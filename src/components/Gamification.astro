            <div class="h-7 w-7 rounded-full bg-gradient-to-br from-[oklch(0.72_0.14_240)] to-[oklch(0.65_0.20_300)]"></div>
            <span class="text-sm font-medium flex-1">Adam L.</span>
            <span class="text-xs text-[var(--color-muted)] tabular-nums">2,480 XP</span>
