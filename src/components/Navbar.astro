---
import { DOCS_GUIDES, DOCS_INSTALLATION, DOCS_CONTRIBUTING, DISCORD_INVITE, GITHUB_REPO } from "../config";
---

<!-- Nav -->
<nav class="sticky top-0 z-50 border-b border-[var(--color-border)] backdrop-blur-xl bg-[var(--color-background)]/80">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 sm:px-6 py-3 sm:py-4">
    <a href="/" class="flex items-center gap-2 sm:gap-3 min-w-0">
      <div class="flex h-8 w-8 sm:h-9 sm:w-9 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br from-[oklch(0.50_0.22_280)] to-[oklch(0.40_0.20_300)] shadow-lg shadow-[var(--color-primary)]/25">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="m21.64 3.64-1.28-1.28a1.21 1.21 0 0 0-1.72 0L2.36 18.64a1.21 1.21 0 0 0 0 1.72l1.28 1.28a1.2 1.2 0 0 0 1.72 0L21.64 5.36a1.2 1.2 0 0 0 0-1.72"/>
          <path d="m14 7 3 3"/><path d="M5 6v4"/><path d="M19 14v4"/><path d="M10 2v2"/><path d="M7 8H3"/><path d="M21 16h-4"/><path d="M11 3H9"/>
        </svg>
      </div>
      <span class="font-heading text-base sm:text-lg font-bold tracking-tight">OpenCauldron</span>
      <span class="hidden sm:inline rounded-full bg-[var(--color-primary)]/10 px-2 py-0.5 text-[10px] font-semibold text-[var(--color-primary)] ring-1 ring-[var(--color-primary)]/20">v0.1.0</span>
    </a>
    <div class="flex items-center gap-5">
      <a href="#features" class="hidden lg:block text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors">Features</a>
      <a href="#providers" class="hidden lg:block text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors">Models</a>
      <a href={DOCS_GUIDES} class="hidden md:block text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors">Guides</a>
      <a href={DOCS_INSTALLATION} class="hidden md:block text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors">Self-host</a>
      <a href={DOCS_CONTRIBUTING} class="hidden md:block text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors">Contribute</a>
      <a href={DISCORD_INVITE} target="_blank" rel="noopener" class="hidden md:block text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors">Discord</a>
      <!-- GitHub icon-only on mobile -->
      <a href={GITHUB_REPO} target="_blank" rel="noopener" class="inline-flex h-9 items-center gap-2 rounded-lg bg-[var(--color-card)] px-3 sm:px-4 text-sm font-medium text-[var(--color-foreground)] ring-1 ring-[var(--color-border)] hover:ring-[var(--color-primary)]/40 transition-all">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        <span class="hidden sm:inline">Star on GitHub</span>
      </a>
      <!-- Mobile menu button -->
      <button id="mobile-menu-btn" class="md:hidden flex h-9 w-9 items-center justify-center rounded-lg text-[var(--color-muted)] hover:text-[var(--color-foreground)] hover:bg-[var(--color-card)] transition-colors cursor-pointer">
        <svg id="menu-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" x2="21" y1="6" y2="6"/><line x1="3" x2="21" y1="12" y2="12"/><line x1="3" x2="21" y1="18" y2="18"/></svg>
        <svg id="close-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
    </div>
  </div>
  <!-- Mobile menu dropdown -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-[var(--color-border)] bg-[var(--color-background)]/95 backdrop-blur-xl">
    <div class="flex flex-col px-4 py-3 gap-1">
      <a href="#cloud-waitlist-form" class="mobile-nav-link group relative inline-flex h-11 items-center justify-center gap-2 rounded-xl px-4 text-sm font-semibold text-white shadow-lg shadow-[var(--color-primary)]/25 mb-1 animate-shimmer overflow-hidden" style="background: linear-gradient(135deg, oklch(0.58 0.22 280), oklch(0.65 0.20 300), oklch(0.68 0.19 280), oklch(0.60 0.22 260)); background-size: 200% 200%;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="m21.64 3.64-1.28-1.28a1.21 1.21 0 0 0-1.72 0L2.36 18.64a1.21 1.21 0 0 0 0 1.72l1.28 1.28a1.2 1.2 0 0 0 1.72 0L21.64 5.36a1.2 1.2 0 0 0 0-1.72"/>
          <path d="m14 7 3 3"/><path d="M5 6v4"/><path d="M19 14v4"/><path d="M10 2v2"/><path d="M7 8H3"/><path d="M21 16h-4"/><path d="M11 3H9"/>
        </svg>
        Join the beta
      </a>
      <p class="px-3 pt-2 pb-1 text-[10px] font-semibold uppercase tracking-wider text-[var(--color-muted)]/70">On this page</p>
      <a href="#features" class="mobile-nav-link rounded-lg px-3 py-2.5 text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] hover:bg-[var(--color-card)] transition-colors">Features</a>
      <a href="#providers" class="mobile-nav-link rounded-lg px-3 py-2.5 text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] hover:bg-[var(--color-card)] transition-colors">Models</a>
      <p class="px-3 pt-3 pb-1 text-[10px] font-semibold uppercase tracking-wider text-[var(--color-muted)]/70">Docs</p>
      <a href={DOCS_GUIDES} class="mobile-nav-link rounded-lg px-3 py-2.5 text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] hover:bg-[var(--color-card)] transition-colors">Guides</a>
      <a href={DOCS_INSTALLATION} class="mobile-nav-link rounded-lg px-3 py-2.5 text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] hover:bg-[var(--color-card)] transition-colors">Self-host</a>
      <a href={DOCS_CONTRIBUTING} class="mobile-nav-link rounded-lg px-3 py-2.5 text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] hover:bg-[var(--color-card)] transition-colors">Contribute</a>
      <p class="px-3 pt-3 pb-1 text-[10px] font-semibold uppercase tracking-wider text-[var(--color-muted)]/70">Community</p>
      <a href={DISCORD_INVITE} target="_blank" rel="noopener" class="mobile-nav-link rounded-lg px-3 py-2.5 text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] hover:bg-[var(--color-card)] transition-colors">Discord</a>
    </div>
  </div>
</nav>


<script>
  // Mobile menu
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');

  mobileMenuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
    menuIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
  });

  document.querySelectorAll('.mobile-nav-link').forEach(link => {
    if (link.tagName === 'A') {
      link.addEventListener('click', () => {
        mobileMenu?.classList.add('hidden');
        menuIcon?.classList.remove('hidden');
        closeIcon?.classList.add('hidden');
      });
    }
  });
</script>
