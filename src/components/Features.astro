---
const features = [
  {
    title: "Multi-model generation",
    description: "15+ image and video models in one interface — Flux, Imagen, Ideogram, Recraft, Runway, Luma, Veo. Pick the right tool for each shot.",
    icon: "layers",
    color: "var(--color-primary)",
  },
  {
    title: "Bring your own keys",
    description: "Use your own Google, Replicate, or Runway keys and pay providers directly. No markup, no middleman. Or use ours and let us handle billing.",
    icon: "key",
    color: "var(--color-sky)",
  },
  {
    title: "Workspaces, roles & invitations",
    description: "Brand-scoped access for clients and freelancers. Token-based invitations, role tiers, and a studio switcher when you run more than one.",
    icon: "users",
    color: "var(--color-fuchsia)",
  },
  {
    title: "Real-time cost tracking",
    description: "Per-user, per-model, per-brand, per-campaign. Daily limits, spend alerts, and a dashboard that surfaces the whole creative budget.",
    icon: "chart",
    color: "var(--color-teal)",
  },
  {
    title: "Live activity feed",
    description: "See what your team is generating, reviewing, and approving — in real time. The studio's heartbeat, not a stale dashboard.",
    icon: "activity",
    color: "var(--color-violet)",
  },
  {
    title: "Advanced editing & workflows",
    description: "Image-to-image with multiple references, Flux 2 Klein edits, LoRA chains, and a workflow registry so power users can ship custom pipelines.",
    icon: "wand",
    color: "var(--color-fuchsia)",
  },
];
---

<!-- Features -->
<section id="features" class="relative z-10 mx-auto max-w-6xl px-4 sm:px-6 py-16 sm:py-24">
  <div class="text-center mb-16">
    <h2 class="font-heading text-3xl font-bold tracking-tight sm:text-4xl">
      Everything you need to
      <span style="background: linear-gradient(135deg, oklch(0.76 0.13 280), oklch(0.65 0.20 300)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">create at scale</span>
    </h2>
    <p class="mt-4 text-[var(--color-muted)] max-w-xl mx-auto text-balance">
      Not just another image generator. OpenCauldron is the full studio for teams that take their creative output seriously.
    </p>
  </div>

  <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
    {features.map((feature) => (
      <div class="group relative rounded-2xl bg-[var(--color-card)] p-5 sm:p-6 ring-1 ring-[var(--color-border)] transition-all duration-300 hover:ring-[var(--color-primary)]/30 hover:-translate-y-1 hover:shadow-lg hover:shadow-[var(--color-primary)]/5">
        <div class="flex items-center gap-3 sm:block">
        <div class="sm:mb-4 flex h-11 w-11 shrink-0 items-center justify-center rounded-lg" style={`background: color-mix(in oklch, ${feature.color} 15%, transparent)`}>
          {feature.icon === "layers" && (
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke={feature.color} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"/><path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"/><path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65"/></svg>
          )}
          {feature.icon === "users" && (
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke={feature.color} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          )}
          {feature.icon === "chart" && (
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke={feature.color} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v16a2 2 0 0 0 2 2h16"/><path d="m19 9-5 5-4-4-3 3"/></svg>
          )}
          {feature.icon === "key" && (
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke={feature.color} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="7.5" cy="15.5" r="5.5"/><path d="m21 2-9.3 9.3"/><path d="M18.5 5.5 21 3"/><path d="m15 8 2.5-2.5"/></svg>
          )}
          {feature.icon === "activity" && (
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke={feature.color} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-2.48a2 2 0 0 0-1.93 1.46l-2.35 8.36a.5.5 0 0 1-.96 0L9.24 2.18a.5.5 0 0 0-.96 0l-2.35 8.36A2 2 0 0 1 4 12H2"/></svg>
          )}
          {feature.icon === "wand" && (
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke={feature.color} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m21.64 3.64-1.28-1.28a1.21 1.21 0 0 0-1.72 0L2.36 18.64a1.21 1.21 0 0 0 0 1.72l1.28 1.28a1.2 1.2 0 0 0 1.72 0L21.64 5.36a1.2 1.2 0 0 0 0-1.72"/><path d="m14 7 3 3"/><path d="M5 6v4"/><path d="M19 14v4"/><path d="M10 2v2"/><path d="M7 8H3"/><path d="M21 16h-4"/><path d="M11 3H9"/></svg>
          )}
        </div>
        <h3 class="font-heading text-base font-semibold sm:mb-1.5">{feature.title}</h3>
        </div>
        <p class="mt-2 sm:mt-0 text-sm leading-relaxed text-[var(--color-muted)]">{feature.description}</p>
      </div>
    ))}
  </div>
</section>
