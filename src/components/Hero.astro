---
import { DISCORD_INVITE, DOCS_INSTALLATION } from "../config";

// Sparkle field behind the hero — first 6 always visible, last 6 desktop-only.
// Color cycles sky → primary → fuchsia → violet per design-system rules.
const sparkles = [
  { top: "8%",  left: "18%", color: "var(--color-sky)",     delay: "0s",   dur: "4.2s", mobile: true  },
  { top: "15%", left: "78%", color: "var(--color-fuchsia)", delay: "1.4s", dur: "5.1s", mobile: true  },
  { top: "32%", left: "8%",  color: "var(--color-primary)", delay: "2.6s", dur: "3.8s", mobile: true  },
  { top: "28%", left: "88%", color: "var(--color-violet)",  delay: "0.7s", dur: "4.6s", mobile: true  },
  { top: "52%", left: "22%", color: "var(--color-fuchsia)", delay: "3.1s", dur: "5.4s", mobile: true  },
  { top: "60%", left: "82%", color: "var(--color-sky)",     delay: "1.9s", dur: "4.0s", mobile: true  },
  { top: "12%", left: "45%", color: "var(--color-violet)",  delay: "2.2s", dur: "5.8s", mobile: false },
  { top: "22%", left: "62%", color: "var(--color-sky)",     delay: "0.4s", dur: "4.4s", mobile: false },
  { top: "42%", left: "38%", color: "var(--color-primary)", delay: "3.5s", dur: "5.2s", mobile: false },
  { top: "68%", left: "12%", color: "var(--color-violet)",  delay: "1.1s", dur: "4.8s", mobile: false },
  { top: "72%", left: "55%", color: "var(--color-fuchsia)", delay: "2.8s", dur: "3.6s", mobile: false },
  { top: "80%", left: "30%", color: "var(--color-sky)",     delay: "0.9s", dur: "5.0s", mobile: false },
];

// Hero bullets: lead with the collaboration story. Brands × creators × agencies
// in one shared workspace, every major model, on-brand by default.
const heroBullets = [
  {
    title: "Brands × creators in one place",
    desc: "Brand presets, shared asset libraries, and approval workflows so every generation stays on-brief.",
  },
  {
    title: "Every major image & video model",
    desc: "Imagen, Flux, Ideogram, Recraft, Runway, Luma, Veo, MiniMax — no subscription tab-juggling.",
  },
  {
    title: "Workspaces, not chat windows",
    desc: "Generate, review, and ship together. Roles for managers, creators, and reviewers — built in.",
  },
  {
    title: "Free during invite-only beta",
    desc: "Free credits while we're in beta. Bring your own provider keys, or use ours.",
  },
];
---

<!-- Hero -->
<section class="relative z-10 mx-auto max-w-6xl px-4 sm:px-6 pt-16 pb-14 sm:pt-32 sm:pb-28">
  <!-- Ambient sparkle field -->
  <div class="sparkle-layer" aria-hidden="true">
    {sparkles.map((s) => (
      <span
        class:list={["sparkle", !s.mobile && "hidden sm:block"]}
        style={`top: ${s.top}; left: ${s.left}; color: ${s.color}; --sparkle-delay: ${s.delay}; --sparkle-duration: ${s.dur};`}
      />
    ))}
  </div>

  <div class="relative z-10 flex flex-col items-center text-center">
    <!-- Badge -->
    <div class="animate-fade-up inline-flex items-center gap-2 rounded-full bg-[var(--color-fuchsia)]/10 px-4 py-1.5 text-xs font-semibold text-[var(--color-fuchsia)] ring-1 ring-[var(--color-fuchsia)]/20 mb-8">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="m21.64 3.64-1.28-1.28a1.21 1.21 0 0 0-1.72 0L2.36 18.64a1.21 1.21 0 0 0 0 1.72l1.28 1.28a1.2 1.2 0 0 0 1.72 0L21.64 5.36a1.2 1.2 0 0 0 0-1.72"/>
        <path d="m14 7 3 3"/><path d="M5 6v4"/><path d="M19 14v4"/><path d="M10 2v2"/><path d="M7 8H3"/><path d="M21 16h-4"/><path d="M11 3H9"/>
      </svg>
      Invite-only beta &middot; For brands &amp; creators
    </div>

    <!-- Heading -->
    <h1 class="animate-fade-up delay-100 font-heading text-4xl font-extrabold tracking-tight sm:text-5xl lg:text-7xl max-w-4xl">
      The collaborative
      <span class="block leading-[1.2] pb-1" style="background: linear-gradient(135deg, oklch(0.80 0.12 280), oklch(0.68 0.19 280), oklch(0.65 0.20 310)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
        AI creative studio.
      </span>
    </h1>

    <!-- Subheading -->
    <p class="animate-fade-up delay-200 mt-6 max-w-2xl text-lg leading-relaxed text-balance text-[var(--color-muted)]">
      A shared workspace where brand teams, marketers, creators, and agencies generate on-brand images and video together &mdash; every major AI model, from Imagen and Flux to Runway and Veo, in one place.
    </p>

    <!-- Waitlist + bullets card -->
    <div class="animate-fade-up delay-300 mt-10 w-full max-w-2xl">
      <div class="rounded-2xl ring-1 ring-[var(--color-border)] bg-[var(--color-card)] overflow-hidden shadow-2xl shadow-[var(--color-primary)]/5">
        <!-- Waitlist form -->
        <div class="p-5 sm:p-6 border-b border-[var(--color-border)]">
          <form
            id="cloud-waitlist-form"
            name="cloud-waitlist"
            method="POST"
            action="/?waitlist=ok"
            data-netlify="true"
            netlify-honeypot="bot-field"
            class="text-left"
          >
            <input type="hidden" name="form-name" value="cloud-waitlist" />
            <p class="hidden"><label>Don't fill this out: <input name="bot-field" /></label></p>
            <label for="cloud-waitlist-email" class="block text-xs font-semibold text-[var(--color-muted)] uppercase tracking-wider mb-2">
              Get an invite
            </label>
            <div class="flex flex-col sm:flex-row gap-3">
              <input
                id="cloud-waitlist-email"
                type="email"
                name="email"
                required
                placeholder="you@somewhere.cool"
                class="w-full sm:flex-1 sm:w-auto min-w-0 shrink-0 h-12 rounded-lg bg-[var(--color-background)] px-4 text-sm text-[var(--color-foreground)] ring-1 ring-[var(--color-border)] focus:ring-[var(--color-primary)] focus:outline-none transition-all placeholder:text-[var(--color-muted)]/50"
              />
              <button
                type="submit"
                class="shrink-0 inline-flex w-full sm:w-auto h-12 items-center justify-center gap-2 rounded-lg px-6 text-sm font-semibold text-white transition-all hover:shadow-xl hover:shadow-[var(--color-primary)]/20 active:translate-y-px animate-shimmer"
                style="background: linear-gradient(135deg, oklch(0.58 0.22 280), oklch(0.65 0.20 300), oklch(0.68 0.19 280), oklch(0.60 0.22 260));"
              >
                Join the beta
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </button>
            </div>
            <p class="mt-2 text-xs text-[var(--color-muted)]">We'll only email you when your beta invite is ready. No spam, ever.</p>
          </form>
          <div id="cloud-waitlist-success" class="hidden items-center gap-3 text-left">
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-[var(--color-teal)]/10">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-teal)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            </div>
            <div>
              <p class="text-sm font-medium text-[var(--color-foreground)]">You're on the list.</p>
              <p class="text-xs text-[var(--color-muted)]">Check your inbox &mdash; we'll be in touch as invites open.</p>
            </div>
          </div>
        </div>

        <!-- Feature bullets -->
        <div class="grid grid-cols-1 sm:grid-cols-2 divide-y sm:divide-y-0 sm:divide-x divide-[var(--color-border)]">
          {heroBullets.map((b, i) => (
            <div class:list={[
              "p-4 sm:p-5 text-left",
              i >= 2 && "sm:border-t sm:border-[var(--color-border)]",
            ]}>
              <div class="flex items-start gap-3">
                <div class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-md bg-[var(--color-primary)]/10 ring-1 ring-[var(--color-primary)]/20">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                </div>
                <div>
                  <p class="text-sm font-semibold text-[var(--color-foreground)]">{b.title}</p>
                  <p class="text-xs text-[var(--color-muted)] mt-1 leading-relaxed">{b.desc}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Secondary CTAs -->
    <div class="animate-fade-up delay-400 mt-8 flex flex-col sm:flex-row sm:flex-wrap items-center justify-center gap-x-6 gap-y-3 text-sm">
      <a
        href="#open-core"
        class="inline-flex items-center gap-2 font-medium text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18c-4.51 2-5-2-7-2"/><path d="M15 22v-4a3.5 3.5 0 0 0-1-2.7c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 1.5 5 1.5 5 1.5c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 8.5c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/></svg>
        Open core &middot; self-hostable
      </a>
      <span class="hidden sm:inline text-[var(--color-border)]">&middot;</span>
      <a
        href={DISCORD_INVITE}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 font-medium text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
        Join the community
      </a>
    </div>
  </div>
</section>

<!-- Hidden Netlify form registration so the build picks up cloud-waitlist -->
<form name="cloud-waitlist" netlify netlify-honeypot="bot-field" hidden>
  <input type="email" name="email" />
  <input name="bot-field" />
</form>

<script>
  // Cloud waitlist submission (Netlify-friendly)
  document.addEventListener('DOMContentLoaded', () => {
    const waitlistForm = document.getElementById('cloud-waitlist-form') as HTMLFormElement | null;
    const waitlistSuccess = document.getElementById('cloud-waitlist-success');
    waitlistForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = new FormData(waitlistForm);
      try {
        await fetch('/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams(data as any).toString(),
        });
        waitlistForm.classList.add('hidden');
        waitlistSuccess?.classList.remove('hidden');
        waitlistSuccess?.classList.add('flex');
      } catch {
        waitlistForm.submit();
      }
    });
  });
</script>
