      <p class="text-sm text-[var(--color-muted)] mb-6">Tell us which AI model or provider you'd like to see in OpenCauldron.</p>

      <!-- Netlify form -->
      <form id="provider-form" name="provider-request" method="POST" data-netlify="true" netlify-honeypot="bot-field" class="flex flex-col gap-4">
        <input type="hidden" name="form-name" value="provider-request" />
        <p class="hidden"><label>Don't fill this out: <input name="bot-field" /></label></p>

        <div>
          <label for="provider-name" class="block text-sm font-medium mb-1.5">Provider / Model name</label>
          <input type="text" id="provider-name" name="provider-name" required placeholder="e.g. Midjourney"
            class="w-full rounded-lg bg-[var(--color-background)] px-4 py-2.5 text-sm ring-1 ring-[var(--color-border)] focus:ring-[var(--color-primary)] focus:outline-none transition-all placeholder:text-[var(--color-muted)]/50" />
        </div>

        <div>
          <label for="provider-url" class="block text-sm font-medium mb-1.5">Website URL <span class="text-[var(--color-muted)]">(optional)</span></label>
          <input type="url" id="provider-url" name="provider-url" placeholder="https://"
            class="w-full rounded-lg bg-[var(--color-background)] px-4 py-2.5 text-sm ring-1 ring-[var(--color-border)] focus:ring-[var(--color-primary)] focus:outline-none transition-all placeholder:text-[var(--color-muted)]/50" />
        </div>

        <div>
          <label for="requester-email" class="block text-sm font-medium mb-1.5">Your email <span class="text-[var(--color-muted)]">(optional)</span></label>
          <input type="email" id="requester-email" name="email" placeholder="you@example.com"
            class="w-full rounded-lg bg-[var(--color-background)] px-4 py-2.5 text-sm ring-1 ring-[var(--color-border)] focus:ring-[var(--color-primary)] focus:outline-none transition-all placeholder:text-[var(--color-muted)]/50" />
        </div>

        <button type="submit"
          class="mt-2 inline-flex h-11 items-center justify-center rounded-xl px-6 text-sm font-semibold text-white transition-all hover:shadow-lg hover:shadow-[var(--color-primary)]/20 active:translate-y-px cursor-pointer"
          style="background: linear-gradient(135deg, oklch(0.58 0.22 280), oklch(0.65 0.20 300));">
          Submit Request
        </button>
      </form>

      <!-- Success message -->
      <div id="form-success" class="hidden text-center py-6">
        <div class="flex h-12 w-12 items-center justify-center rounded-full bg-[var(--color-teal)]/10 mx-auto mb-4">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-teal)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
        </div>
        <p class="font-heading font-semibold text-lg">Thanks!</p>
        <p class="text-sm text-[var(--color-muted)] mt-1">We'll review your request and consider adding it.</p>
      </div>
    </div>
  </div>

