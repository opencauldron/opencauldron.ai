  <!-- GSAP showcase animations -->
  <script>
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener('DOMContentLoaded', () => {
      const section = document.getElementById('app-showcase');
      const header = document.querySelector('[data-showcase-header]');
      const browser = document.querySelector('[data-showcase-browser]');
      const shimmer = document.querySelector('[data-shimmer]');
      const caption = document.querySelector('[data-showcase-caption]');
      const cauldronImg = document.querySelector('[data-cauldron-img]') as HTMLElement;
      const cauldronBlur = document.querySelector('[data-cauldron-blur]') as HTMLElement;

      if (section && browser) {
        gsap.set(header, { opacity: 0, y: 24 });
        gsap.set(browser, { opacity: 0, y: 60, rotateX: 8, transformOrigin: 'center bottom' });
        gsap.set(caption, { opacity: 0, y: 12 });

        const revealTl = gsap.timeline({ paused: true });

        revealTl
          .to(header, { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out' })
          .to(browser, { opacity: 1, y: 0, rotateX: 0, duration: 1, ease: 'power3.out' }, '-=0.3')
          .to(shimmer, { x: '200%', duration: 0.8, ease: 'power2.inOut' }, '-=0.4')
          .to(caption, { opacity: 1, y: 0, duration: 0.5, ease: 'power2.out' }, '-=0.4')
          .add(() => { startWalkthrough(); });

        ScrollTrigger.create({
          trigger: section,
          start: 'top 75%',
          once: true,
          onEnter: () => revealTl.play()
        });
      }

      // === Walkthrough logic ===
      const walkSteps = document.querySelectorAll('.walk-step');
      const walkTabEls = document.querySelectorAll('[data-walk-tab]');
      const typingTarget = document.querySelector('[data-typing-target]') as HTMLElement;
      const typingCursor = document.querySelector('[data-typing-cursor]') as HTMLElement;
      const charCount = document.querySelector('[data-char-count]') as HTMLElement;

      let walkCurrent = 0;
      let walkTimer: ReturnType<typeof setInterval> | null = null;
      let walkAnimating = false;
      let typingInterval: ReturnType<typeof setInterval> | null = null;
      let walkthroughStarted = false;
      const WALK_INTERVAL = 4500;

      const walkCaptions = [
        'Write a detailed prompt describing exactly what you want to create.',
        'Choose from 5+ AI models — each with different strengths and pricing.',
        'Use templates or AI rewrite to enhance your prompt automatically.',
        'Fine-tune aspect ratio, resolution, format, and advanced settings.',
        'Hit generate and watch your creation come to life.',
      ];

      function startTyping() {
        if (!typingTarget) return;
        const fullText = typingTarget.textContent || '';
        typingTarget.textContent = '';
        if (charCount) charCount.textContent = '0';
        if (typingCursor) typingCursor.style.display = 'inline-block';
        let i = 0;
        typingInterval = setInterval(() => {
          if (i < fullText.length) {
            typingTarget.textContent = fullText.slice(0, i + 1);
            if (charCount) charCount.textContent = String(i + 1);
            i++;
          } else {
            if (typingInterval) clearInterval(typingInterval);
            typingInterval = null;
          }
        }, 18);
      }

      function stopTyping() {
        if (typingInterval) {
          clearInterval(typingInterval);
          typingInterval = null;
        }
      }

      function goToStep(idx: number) {
        if (walkAnimating || idx === walkCurrent) return;
        if (idx < 0 || idx >= walkSteps.length) return;
        walkAnimating = true;
        stopTyping();

        const currentStep = walkSteps[walkCurrent] as HTMLElement;
        const nextStep = walkSteps[idx] as HTMLElement;
        const captionText = document.querySelector('[data-caption-text]');

        // Animate out
        gsap.to(currentStep, {
          opacity: 0,
          x: idx > walkCurrent ? -20 : 20,
          duration: 0.25,
          ease: 'power2.in',
          onComplete: () => {
            currentStep.classList.remove('active');
            gsap.set(currentStep, { x: 0 });

            // Animate in
            gsap.set(nextStep, { opacity: 0, x: idx > walkCurrent ? 20 : -20 });
            nextStep.classList.add('active');
            gsap.to(nextStep, {
              opacity: 1,
              x: 0,
              duration: 0.35,
              ease: 'power2.out',
              onComplete: () => {
                walkAnimating = false;
                // Start typing on step 0
                if (idx === 0) startTyping();
                // Reveal image on step 4
                if (idx === 4) {
                  if (cauldronBlur) gsap.to(cauldronBlur, { opacity: 0, duration: 0.5 });
                  if (cauldronImg) gsap.to(cauldronImg, { opacity: 1, scale: 1, duration: 0.8, ease: 'back.out(1.4)' });
                } else {
                  // Reset image when leaving step 4
                  if (walkCurrent === 4) {
                    if (cauldronBlur) gsap.to(cauldronBlur, { opacity: 1, duration: 0.3 });
                    if (cauldronImg) gsap.set(cauldronImg, { opacity: 0, scale: 0.95 });
                  }
                }
                walkCurrent = idx;
              }
            });
          }
        });

        // Update tabs
        walkTabEls.forEach((t, i) => {
          t.classList.toggle('active', i === idx);
        });
        const activeTab = walkTabEls[idx] as HTMLElement;
        if (activeTab) positionIndicator(activeTab);

        // Update caption
        if (captionText) {
          gsap.to(captionText, {
            opacity: 0,
            duration: 0.15,
            onComplete: () => {
              captionText.textContent = walkCaptions[idx];
              gsap.to(captionText, { opacity: 1, duration: 0.2 });
            }
          });
        }
      }

      function nextWalkStep() {
        const next = (walkCurrent + 1) % walkSteps.length;
        goToStep(next);
      }

      function startWalkthrough() {
        if (walkthroughStarted) return;
        walkthroughStarted = true;
        if (cauldronImg) gsap.set(cauldronImg, { opacity: 0, scale: 0.95 });
        startTyping();
        // Update caption to step 0
        const captionText = document.querySelector('[data-caption-text]');
        if (captionText) captionText.textContent = walkCaptions[0];
        walkTimer = setInterval(nextWalkStep, WALK_INTERVAL);
      }

      function resetWalkTimer() {
        if (walkTimer) clearInterval(walkTimer);
        walkTimer = setInterval(nextWalkStep, WALK_INTERVAL);
      }

      // Step tabs (replacing old screen tabs + walk dots)
      const walkTabs = document.querySelectorAll('[data-walk-tab]');
      const indicator = document.querySelector('[data-tab-indicator]') as HTMLElement;

      function positionIndicator(tab: HTMLElement) {
        if (!indicator) return;
        gsap.to(indicator, { x: tab.offsetLeft, width: tab.offsetWidth, duration: 0.3, ease: 'power2.inOut' });
      }

      const firstTab = document.querySelector('[data-walk-tab].active') as HTMLElement;
      if (firstTab && indicator) {
        gsap.set(indicator, { x: firstTab.offsetLeft, width: firstTab.offsetWidth });
      }

      walkTabs.forEach((tab, i) => {
        tab.addEventListener('click', () => {
          goToStep(i);
          resetWalkTimer();
        });
      });

      window.addEventListener('resize', () => {
        const activeTab = document.querySelector('[data-walk-tab].active') as HTMLElement;
        if (activeTab) positionIndicator(activeTab);
      });
    });
  </script>

  <!-- Install tab switching script -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const tabs = document.querySelectorAll('.install-tab');
      const panels = document.querySelectorAll('.install-panel');
      const copyBtn = document.getElementById('copy-btn');

      tabs.forEach(tab => {
        tab.addEventListener('click', () => {
          const idx = tab.getAttribute('data-tab');

          tabs.forEach(t => {
            t.classList.remove('text-[var(--color-primary)]', 'border-[var(--color-primary)]');
            t.classList.add('text-[var(--color-muted)]', 'border-transparent');
          });
          tab.classList.remove('text-[var(--color-muted)]', 'border-transparent');
          tab.classList.add('text-[var(--color-primary)]', 'border-[var(--color-primary)]');

          panels.forEach(p => p.classList.add('hidden'));
          document.querySelector(`[data-panel="${idx}"]`)?.classList.remove('hidden');
        });
      });

      copyBtn?.addEventListener('click', () => {
        const visible = document.querySelector('.install-panel:not(.hidden)');
        const text = visible?.textContent?.replace('$ ', '').trim() || '';
        navigator.clipboard.writeText(text);
        copyBtn.title = 'Copied!';
        setTimeout(() => { copyBtn.title = 'Copy to clipboard'; }, 2000);
      });
    });

    // Mobile menu
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuIcon = document.getElementById('menu-icon');
    const closeIcon = document.getElementById('close-icon');

    mobileMenuBtn?.addEventListener('click', () => {
      const isOpen = !mobileMenu?.classList.contains('hidden');
      mobileMenu?.classList.toggle('hidden');
      menuIcon?.classList.toggle('hidden');
      closeIcon?.classList.toggle('hidden');
    });

    document.querySelectorAll('.mobile-nav-link').forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu?.classList.add('hidden');
        menuIcon?.classList.remove('hidden');
        closeIcon?.classList.add('hidden');
      });
    });

    // Provider request modal
    const modal = document.getElementById('request-modal');
    const openBtn = document.getElementById('request-provider-btn');
    const closeBtn = document.getElementById('modal-close');
    const backdrop = document.getElementById('modal-backdrop');
    const form = document.getElementById('provider-form') as HTMLFormElement;
    const formSuccess = document.getElementById('form-success');

    function openModal() {
      modal?.classList.remove('hidden');
      modal?.classList.add('flex');
      document.body.style.overflow = 'hidden';
    }
    function closeModal() {
      modal?.classList.add('hidden');
      modal?.classList.remove('flex');
      document.body.style.overflow = '';
    }

    openBtn?.addEventListener('click', openModal);
    closeBtn?.addEventListener('click', closeModal);
    backdrop?.addEventListener('click', closeModal);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeModal();
    });

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = new FormData(form);
      try {
        await fetch('/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams(data as any).toString(),
        });
        form.classList.add('hidden');
        formSuccess?.classList.remove('hidden');
        setTimeout(closeModal, 2500);
      } catch {
        // Fall back to normal form submission
        form.submit();
      }
    });
  </script>
</Layout>
