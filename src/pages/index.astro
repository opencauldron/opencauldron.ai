---
import Layout from "../layouts/Layout.astro";

const features = [
  {
    title: "Multi-Model Generation",
    description: "Flux Pro, Imagen 4, Ideogram 3, Recraft V3, and more. One interface, many engines — pick the best model for each job.",
    icon: "layers",
  },
  {
    title: "Bring Your Own Keys",
    description: "Use your own API keys and pay providers directly. No markup, no middleman. You control your costs.",
    icon: "key",
  },
  {
    title: "Brand Management",
    description: "Tag generations by brand, organize assets, and keep creative output consistent across teams.",
    icon: "tags",
  },
  {
    title: "Usage & Cost Tracking",
    description: "Monitor API costs per user, per model, per brand. Know exactly where your budget goes.",
    icon: "chart",
  },
  {
    title: "Team Collaboration",
    description: "Shared gallery, leaderboards, and user profiles. See what your team is creating.",
    icon: "users",
  },
  {
    title: "Self-Host Everything",
    description: "Your database, your storage, your auth provider. Ships with sensible defaults, but nothing is locked in.",
    icon: "server",
  },
];

const techStack = [
  { name: "Next.js", category: "Framework", logo: "/logos/nextjs.png" },
  { name: "Tailwind CSS v4", category: "Styling", logo: "/logos/tailwind.png" },
  { name: "Drizzle ORM", category: "Database", logo: "/logos/drizzle.png" },
  { name: "Neon Postgres", category: "Database", logo: "/logos/neon.png" },
  { name: "Cloudflare R2", category: "Storage", logo: "/logos/cloudflare.png" },
  { name: "NextAuth.js", category: "Auth", logo: "/logos/nextauth.png" },
];

const imageProviders = [
  { name: "Flux Pro", provider: "Replicate / BFL", logo: "/logos/replicate.png" },
  { name: "Imagen 4", provider: "Google", logo: "/logos/google.png" },
  { name: "Ideogram 3", provider: "Ideogram", logo: "/logos/ideogram.png" },
  { name: "Recraft V3", provider: "Recraft", logo: "/logos/recraft.png" },
  { name: "DALL-E 3", provider: "OpenAI", logo: "/logos/openai.png" },
  { name: "Stable Diffusion", provider: "Stability AI", logo: "/logos/stability.png" },
];

const videoProviders = [
  { name: "Kling", provider: "Kuaishou", logo: "/logos/kling.png" },
  { name: "Gen-3 Alpha", provider: "Runway", logo: "/logos/runway.png" },
  { name: "Veo 2", provider: "Google DeepMind", logo: "/logos/google-veo.png" },
  { name: "Hailuo", provider: "Minimax", logo: "/logos/minimax.png" },
];

const installMethods = [
  { label: "git", commands: ["git clone https://github.com/opencauldron/opencauldron", "cd opencauldron", "bun install", "bun run dev"] },
  { label: "docker", commands: ["docker run -p 3000:3000 ghcr.io/opencauldron/opencauldron:latest"] },
  { label: "npm", commands: ["npx create-opencauldron@latest"] },
];
---

<Layout>
  <!-- Floating sparkle particles -->
  <div class="pointer-events-none fixed inset-0 overflow-hidden z-0" aria-hidden="true">
    {Array.from({ length: 12 }).map((_, i) => (
      <div
        class="absolute rounded-full"
        style={`
          width: ${2 + (i % 3)}px;
          height: ${2 + (i % 3)}px;
          left: ${8 + (i * 7.5)}%;
          top: ${10 + ((i * 17) % 80)}%;
          background: oklch(0.75 0.15 ${260 + (i * 8)}deg);
          animation: sparkle-pulse ${3 + (i % 4)}s ease-in-out infinite;
          animation-delay: ${(i * 0.5)}s;
        `}
      />
    ))}
  </div>

  <!-- Nav -->
  <nav class="sticky top-0 z-50 border-b border-[var(--color-border)] backdrop-blur-xl bg-[var(--color-background)]/80">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
      <a href="/" class="flex items-center gap-3">
        <div class="flex h-9 w-9 items-center justify-center rounded-xl bg-gradient-to-br from-[oklch(0.50_0.22_280)] to-[oklch(0.40_0.20_300)] shadow-lg shadow-[var(--color-primary)]/25">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="m21.64 3.64-1.28-1.28a1.21 1.21 0 0 0-1.72 0L2.36 18.64a1.21 1.21 0 0 0 0 1.72l1.28 1.28a1.2 1.2 0 0 0 1.72 0L21.64 5.36a1.2 1.2 0 0 0 0-1.72"/>
            <path d="m14 7 3 3"/><path d="M5 6v4"/><path d="M19 14v4"/><path d="M10 2v2"/><path d="M7 8H3"/><path d="M21 16h-4"/><path d="M11 3H9"/>
          </svg>
        </div>
        <span class="font-heading text-lg font-bold tracking-tight">OpenCauldron</span>
        <span class="rounded-full bg-[var(--color-primary)]/10 px-2 py-0.5 text-[10px] font-semibold text-[var(--color-primary)] ring-1 ring-[var(--color-primary)]/20">v0.1.0</span>
      </a>
      <div class="flex items-center gap-5">
        <a href="#features" class="hidden sm:block text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors">Features</a>
        <a href="#stack" class="hidden sm:block text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors">Stack</a>
        <a href="/docs/introduction/" class="hidden sm:block text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors">Docs</a>
        <a href="https://discord.gg/opencauldron" target="_blank" rel="noopener" class="hidden sm:block text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors">Discord</a>
        <a href="https://github.com/opencauldron/opencauldron" target="_blank" rel="noopener" class="inline-flex h-9 items-center gap-2 rounded-lg bg-[var(--color-card)] px-4 text-sm font-medium text-[var(--color-foreground)] ring-1 ring-[var(--color-border)] hover:ring-[var(--color-primary)]/40 transition-all">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          Star on GitHub
        </a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="relative z-10 mx-auto max-w-6xl px-6 pt-24 pb-20 sm:pt-32 sm:pb-28">
    <div class="flex flex-col items-center text-center">
      <!-- Badge -->
      <div class="animate-fade-up inline-flex items-center gap-2 rounded-full bg-[var(--color-primary)]/10 px-4 py-1.5 text-xs font-semibold text-[var(--color-primary)] ring-1 ring-[var(--color-primary)]/20 mb-8">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[var(--color-primary)] opacity-75"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-[var(--color-primary)]"></span>
        </span>
        Free &middot; Open Source &middot; Self-Hostable
      </div>

      <!-- Heading -->
      <h1 class="animate-fade-up delay-100 font-heading text-5xl font-extrabold tracking-tight sm:text-7xl max-w-4xl">
        The open source
        <span class="block" style="background: linear-gradient(135deg, oklch(0.80 0.12 280), oklch(0.68 0.19 280), oklch(0.65 0.20 310)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
          AI media studio
        </span>
      </h1>

      <!-- Subheading -->
      <p class="animate-fade-up delay-200 mt-6 max-w-2xl text-lg leading-relaxed text-[var(--color-muted)]">
        The AI media studio for creators, teams, and brands. Your keys, your infrastructure, your data.
      </p>

      <!-- Install methods -->
      <div class="animate-fade-up delay-300 mt-10 w-full max-w-2xl">
        <div class="rounded-2xl ring-1 ring-[var(--color-border)] bg-[var(--color-card)] overflow-hidden shadow-2xl shadow-[var(--color-primary)]/5">
          <!-- Tab bar -->
          <div class="flex items-center border-b border-[var(--color-border)]" id="install-tabs">
            {installMethods.map((method, i) => (
              <button
                data-tab={i}
                class:list={[
                  "install-tab px-5 py-3 text-xs font-medium transition-colors border-b-2 cursor-pointer",
                  i === 0
                    ? "text-[var(--color-primary)] border-[var(--color-primary)]"
                    : "text-[var(--color-muted)] border-transparent hover:text-[var(--color-foreground)]",
                ]}
              >
                {method.label}
              </button>
            ))}
            <div class="flex-1" />
            <button id="copy-btn" class="px-4 py-3 text-xs text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors cursor-pointer" title="Copy to clipboard">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
            </button>
          </div>
          <!-- Command panels -->
          <div class="p-5 font-mono text-sm leading-relaxed text-left">
            {installMethods.map((method, i) => (
              <div data-panel={i} class:list={["install-panel", i !== 0 && "hidden"]}>
                {method.commands.map((cmd, j) => (
                  <p class:list={[j > 0 && "mt-1"]}><span class="text-[var(--color-muted)]">$</span> <span class="text-[var(--color-primary)]">{cmd}</span></p>
                ))}
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- CTAs -->
      <div class="animate-fade-up delay-400 mt-8 flex flex-col sm:flex-row items-center gap-4">
        <a href="https://github.com/opencauldron/opencauldron" target="_blank" rel="noopener"
          class="inline-flex h-12 items-center gap-2.5 rounded-xl px-7 text-sm font-semibold text-white transition-all hover:shadow-xl hover:shadow-[var(--color-primary)]/20 active:translate-y-px animate-shimmer"
          style="background: linear-gradient(135deg, oklch(0.58 0.22 280), oklch(0.65 0.20 300), oklch(0.68 0.19 280), oklch(0.60 0.22 260));">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          View on GitHub
        </a>
        <a href="/docs/introduction/"
          class="inline-flex h-12 items-center gap-2 rounded-xl px-7 text-sm font-medium text-[var(--color-foreground)] ring-1 ring-[var(--color-border)] hover:ring-[var(--color-primary)]/40 hover:bg-[var(--color-card)] transition-all">
          Read the Docs
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="relative z-10 mx-auto max-w-4xl px-6 pb-20">
    <div class="animate-fade-up delay-500 grid grid-cols-2 sm:grid-cols-4 gap-4">
      <div class="text-center p-5 rounded-xl ring-1 ring-[var(--color-border)] bg-[var(--color-card)]">
        <p class="font-heading text-2xl font-bold text-[var(--color-foreground)]">10+</p>
        <p class="text-xs text-[var(--color-muted)] mt-1">AI Models</p>
      </div>
      <div class="text-center p-5 rounded-xl ring-1 ring-[var(--color-border)] bg-[var(--color-card)]">
        <p class="font-heading text-2xl font-bold text-[var(--color-foreground)]">100%</p>
        <p class="text-xs text-[var(--color-muted)] mt-1">Open Source</p>
      </div>
      <div class="text-center p-5 rounded-xl ring-1 ring-[var(--color-border)] bg-[var(--color-card)]">
        <p class="font-heading text-2xl font-bold text-[var(--color-foreground)]">MIT</p>
        <p class="text-xs text-[var(--color-muted)] mt-1">Licensed</p>
      </div>
      <div class="text-center p-5 rounded-xl ring-1 ring-[var(--color-border)] bg-[var(--color-card)]">
        <p class="font-heading text-2xl font-bold text-[var(--color-foreground)]">0</p>
        <p class="text-xs text-[var(--color-muted)] mt-1">Data Collected</p>
      </div>
    </div>
  </section>


  <!-- Features -->
  <section id="features" class="relative z-10 mx-auto max-w-6xl px-6 py-24">
    <div class="text-center mb-16">
      <h2 class="font-heading text-3xl font-bold tracking-tight sm:text-4xl">
        Everything you need to
        <span style="background: linear-gradient(135deg, oklch(0.76 0.13 280), oklch(0.65 0.20 300)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">generate at scale</span>
      </h2>
      <p class="mt-4 text-[var(--color-muted)] max-w-xl mx-auto">
        Not just another image generator. OpenCauldron is a full studio for teams that take their creative output seriously.
      </p>
    </div>

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {features.map((feature) => (
        <div class="group relative rounded-2xl bg-[var(--color-card)] p-6 ring-1 ring-[var(--color-border)] transition-all duration-300 hover:ring-[var(--color-primary)]/30 hover:-translate-y-1 hover:shadow-lg hover:shadow-[var(--color-primary)]/5">
          <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-lg bg-[var(--color-primary)]/10">
            {feature.icon === "layers" && (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"/><path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"/><path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65"/></svg>
            )}
            {feature.icon === "tags" && (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 5 6.3 6.3a2.4 2.4 0 0 1 0 3.4L17 19"/><path d="M9.586 5.586A2 2 0 0 0 8.172 5H3a1 1 0 0 0-1 1v5.172a2 2 0 0 0 .586 1.414L8.29 18.29a2.426 2.426 0 0 0 3.42 0l3.58-3.58a2.426 2.426 0 0 0 0-3.42z"/><circle cx="6.5" cy="9.5" r=".5" fill="var(--color-primary)"/></svg>
            )}
            {feature.icon === "sparkles" && (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/><path d="M5 3v4"/><path d="M19 17v4"/><path d="M3 5h4"/><path d="M17 19h4"/></svg>
            )}
            {feature.icon === "chart" && (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v16a2 2 0 0 0 2 2h16"/><path d="m19 9-5 5-4-4-3 3"/></svg>
            )}
            {feature.icon === "users" && (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            )}
            {feature.icon === "key" && (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="7.5" cy="15.5" r="5.5"/><path d="m21 2-9.3 9.3"/><path d="M18.5 5.5 21 3"/><path d="m15 8 2.5-2.5"/></svg>
            )}
            {feature.icon === "server" && (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="8" x="2" y="2" rx="2" ry="2"/><rect width="20" height="8" x="2" y="14" rx="2" ry="2"/><line x1="6" x2="6.01" y1="6" y2="6"/><line x1="6" x2="6.01" y1="18" y2="18"/></svg>
            )}
          </div>
          <h3 class="font-heading text-base font-semibold mb-1.5">{feature.title}</h3>
          <p class="text-sm leading-relaxed text-[var(--color-muted)]">{feature.description}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Gamification -->
  <section class="relative z-10 mx-auto max-w-6xl px-6 py-24">
    <div class="grid gap-10 lg:grid-cols-2 items-center">
      <!-- Copy -->
      <div>
        <div class="inline-flex items-center gap-2 rounded-full bg-[var(--color-fuchsia)]/10 px-4 py-1.5 text-xs font-semibold text-[var(--color-fuchsia)] ring-1 ring-[var(--color-fuchsia)]/20 mb-6">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          Gamification built in
        </div>
        <h2 class="font-heading text-3xl font-bold tracking-tight sm:text-4xl">
          Level up your
          <span style="background: linear-gradient(135deg, oklch(0.68 0.20 325), oklch(0.65 0.20 300)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">creative team</span>
        </h2>
        <p class="mt-4 text-[var(--color-muted)] leading-relaxed">
          OpenCauldron turns generation into progression. Every creation earns XP, unlocks achievements, and moves you up the leaderboard. Video generation unlocks at Level 3.
        </p>
        <div class="mt-8 space-y-4">
          <div class="flex items-start gap-3">
            <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-[var(--color-fuchsia)]/10 mt-0.5">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-fuchsia)" stroke-width="1.5"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
            </div>
            <div>
              <p class="text-sm font-semibold">Earn XP for every generation</p>
              <p class="text-xs text-[var(--color-muted)] mt-0.5">Image and video generations award XP. Pro models give more.</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-[var(--color-primary)]/10 mt-0.5">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
            </div>
            <div>
              <p class="text-sm font-semibold">Unlock feats and achievements</p>
              <p class="text-xs text-[var(--color-muted)] mt-0.5">Hit milestones, build streaks, explore models — earn badges along the way.</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-[var(--color-sky)]/10 mt-0.5">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-sky)" stroke-width="1.5"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5C7 4 9 7 12 7s5-3 7.5-3a2.5 2.5 0 0 1 0 5H18"/><path d="M18 15h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M6 15H4.5a2.5 2.5 0 0 1 0 5H6"/><path d="M18 21h1.5a2.5 2.5 0 0 0 0-5H18"/><line x1="6" x2="18" y1="9" y2="9"/><line x1="6" x2="18" y1="15" y2="15"/><line x1="6" x2="18" y1="21" y2="21"/></svg>
            </div>
            <div>
              <p class="text-sm font-semibold">Climb the leaderboard</p>
              <p class="text-xs text-[var(--color-muted)] mt-0.5">Monthly generation rankings plus all-time XP and feat leaderboards.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Visual mockup -->
      <div class="space-y-4">
        <!-- XP Progress card -->
