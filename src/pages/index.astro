---
import Layout from "../layouts/Layout.astro";

const features = [
  {
    title: "Multi-Model Generation",
    description: "Flux Pro, Imagen 4, Ideogram 3, Recraft V3, and more. One interface, many engines — pick the best model for each job.",
    icon: "layers",
  },
  {
    title: "Bring Your Own Keys",
    description: "Use your own API keys and pay providers directly. No markup, no middleman. You control your costs.",
    icon: "key",
  },
  {
    title: "Brand Management",
    description: "Tag generations by brand, organize assets, and keep creative output consistent across teams.",
    icon: "tags",
  },
  {
    title: "Usage & Cost Tracking",
    description: "Monitor API costs per user, per model, per brand. Know exactly where your budget goes.",
    icon: "chart",
  },
  {
    title: "Team Collaboration",
    description: "Shared gallery, leaderboards, and user profiles. See what your team is creating.",
    icon: "users",
  },
  {
    title: "Self-Host Everything",
    description: "Your database, your storage, your auth provider. Ships with sensible defaults, but nothing is locked in.",
    icon: "server",
  },
];

const techStack = [
  { name: "Next.js", category: "Framework", logo: "/logos/nextjs.png" },
  { name: "Tailwind CSS v4", category: "Styling", logo: "/logos/tailwind.png" },
  { name: "Drizzle ORM", category: "Database", logo: "/logos/drizzle.png" },
  { name: "Neon Postgres", category: "Database", logo: "/logos/neon.png" },
  { name: "Cloudflare R2", category: "Storage", logo: "/logos/cloudflare.png" },
  { name: "NextAuth.js", category: "Auth", logo: "/logos/nextauth.png" },
];

const imageProviders = [
  { name: "Flux", logo: "/logos/bfl.png", models: ["Pro"] },
  { name: "Gemini", logo: "/logos/gemini.png", models: ["Imagen 4", "Flash", "Lite", "Ultra", "Fast"] },
  { name: "Ideogram", logo: "/logos/ideogram.png", models: ["v3"] },
  { name: "Recraft", logo: "/logos/recraft.png", models: ["V3"] },
  { name: "OpenAI", logo: "/logos/openai.png", models: ["DALL-E 3"] },
  { name: "Stability AI", logo: "/logos/stability.png", models: ["SDXL"] },
  { name: "Grok", logo: "/logos/xai.png", models: ["Imagine", "Pro"] },
];

const videoProviders = [
  { name: "Wan", logo: "/logos/wan.png", models: ["2.6"] },
  { name: "Kling", logo: "/logos/kling.png", models: ["2.6"] },
  { name: "Sora", logo: "/logos/sora.png", models: ["2", "2 Stable", "2 Pro", "2 Pro Storyboard"] },
  { name: "Seedance", logo: "/logos/seedance.png", models: ["1.5 Pro"] },
  { name: "Runway", logo: "/logos/runway.png", models: ["Gen-3 Alpha"] },
  { name: "Veo", logo: "/logos/google-veo.png", models: ["3"] },
  { name: "Hailuo", logo: "/logos/minimax.png", models: ["Hailuo"] },
];

const installMethods = [
  { label: "git", commands: ["git clone https://github.com/opencauldron/opencauldron", "cd opencauldron", "bun install", "bun run dev"] },
  { label: "docker", commands: ["docker run -p 3000:3000 ghcr.io/opencauldron/opencauldron:latest"] },
  { label: "npm", commands: ["npx create-opencauldron@latest"] },
];
---

<Layout>
  <!-- Floating sparkle particles -->
  <div class="pointer-events-none fixed inset-0 overflow-hidden z-0" aria-hidden="true">
    {Array.from({ length: 12 }).map((_, i) => (
      <div
        class="absolute rounded-full"
        style={`
          width: ${2 + (i % 3)}px;
          height: ${2 + (i % 3)}px;
          left: ${8 + (i * 7.5)}%;
          top: ${10 + ((i * 17) % 80)}%;
          background: oklch(0.75 0.15 ${260 + (i * 8)}deg);
          animation: sparkle-pulse ${3 + (i % 4)}s ease-in-out infinite;
          animation-delay: ${(i * 0.5)}s;
        `}
      />
    ))}
  </div>

  <!-- Nav -->
  <nav class="sticky top-0 z-50 border-b border-[var(--color-border)] backdrop-blur-xl bg-[var(--color-background)]/80">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-4 sm:px-6 py-3 sm:py-4">
      <a href="/" class="flex items-center gap-2 sm:gap-3 min-w-0">
        <div class="flex h-8 w-8 sm:h-9 sm:w-9 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br from-[oklch(0.50_0.22_280)] to-[oklch(0.40_0.20_300)] shadow-lg shadow-[var(--color-primary)]/25">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="m21.64 3.64-1.28-1.28a1.21 1.21 0 0 0-1.72 0L2.36 18.64a1.21 1.21 0 0 0 0 1.72l1.28 1.28a1.2 1.2 0 0 0 1.72 0L21.64 5.36a1.2 1.2 0 0 0 0-1.72"/>
            <path d="m14 7 3 3"/><path d="M5 6v4"/><path d="M19 14v4"/><path d="M10 2v2"/><path d="M7 8H3"/><path d="M21 16h-4"/><path d="M11 3H9"/>
          </svg>
        </div>
        <span class="font-heading text-base sm:text-lg font-bold tracking-tight">OpenCauldron</span>
        <span class="hidden sm:inline rounded-full bg-[var(--color-primary)]/10 px-2 py-0.5 text-[10px] font-semibold text-[var(--color-primary)] ring-1 ring-[var(--color-primary)]/20">v0.1.0</span>
      </a>
      <div class="flex items-center gap-5">
        <a href="#app-showcase" class="hidden md:block text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors">Preview</a>
        <a href="#features" class="hidden md:block text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors">Features</a>
        <a href="#stack" class="hidden md:block text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors">Stack</a>
        <a href="/docs/introduction/" class="hidden md:block text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors">Docs</a>
        <a href="https://discord.gg/opencauldron" target="_blank" rel="noopener" class="hidden md:block text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors">Discord</a>
        <!-- GitHub icon-only on mobile -->
        <a href="https://github.com/opencauldron/opencauldron" target="_blank" rel="noopener" class="inline-flex h-9 items-center gap-2 rounded-lg bg-[var(--color-card)] px-3 sm:px-4 text-sm font-medium text-[var(--color-foreground)] ring-1 ring-[var(--color-border)] hover:ring-[var(--color-primary)]/40 transition-all">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          <span class="hidden sm:inline">Star on GitHub</span>
        </a>
        <!-- Mobile menu button -->
        <button id="mobile-menu-btn" class="md:hidden flex h-9 w-9 items-center justify-center rounded-lg text-[var(--color-muted)] hover:text-[var(--color-foreground)] hover:bg-[var(--color-card)] transition-colors cursor-pointer">
          <svg id="menu-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" x2="21" y1="6" y2="6"/><line x1="3" x2="21" y1="12" y2="12"/><line x1="3" x2="21" y1="18" y2="18"/></svg>
          <svg id="close-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
      </div>
    </div>
    <!-- Mobile menu dropdown -->
    <div id="mobile-menu" class="hidden md:hidden border-t border-[var(--color-border)] bg-[var(--color-background)]/95 backdrop-blur-xl">
      <div class="flex flex-col px-4 py-3 gap-1">
        <a href="#app-showcase" class="mobile-nav-link rounded-lg px-3 py-2.5 text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] hover:bg-[var(--color-card)] transition-colors">Preview</a>
        <a href="#features" class="mobile-nav-link rounded-lg px-3 py-2.5 text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] hover:bg-[var(--color-card)] transition-colors">Features</a>
        <a href="#stack" class="mobile-nav-link rounded-lg px-3 py-2.5 text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] hover:bg-[var(--color-card)] transition-colors">Stack</a>
        <a href="/docs/introduction/" class="mobile-nav-link rounded-lg px-3 py-2.5 text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] hover:bg-[var(--color-card)] transition-colors">Docs</a>
        <a href="https://discord.gg/opencauldron" target="_blank" rel="noopener" class="mobile-nav-link rounded-lg px-3 py-2.5 text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] hover:bg-[var(--color-card)] transition-colors">Discord</a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="relative z-10 mx-auto max-w-6xl px-4 sm:px-6 pt-16 pb-14 sm:pt-32 sm:pb-28">
    <div class="flex flex-col items-center text-center">
      <!-- Badge -->
      <div class="animate-fade-up inline-flex items-center gap-2 rounded-full bg-[var(--color-fuchsia)]/10 px-4 py-1.5 text-xs font-semibold text-[var(--color-fuchsia)] ring-1 ring-[var(--color-fuchsia)]/20 mb-8">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m21.64 3.64-1.28-1.28a1.21 1.21 0 0 0-1.72 0L2.36 18.64a1.21 1.21 0 0 0 0 1.72l1.28 1.28a1.2 1.2 0 0 0 1.72 0L21.64 5.36a1.2 1.2 0 0 0 0-1.72"/>
          <path d="m14 7 3 3"/><path d="M5 6v4"/><path d="M19 14v4"/><path d="M10 2v2"/><path d="M7 8H3"/><path d="M21 16h-4"/><path d="M11 3H9"/>
        </svg>
        Free &middot; Open Source &middot; Self-Hostable
      </div>

      <!-- Heading -->
      <h1 class="animate-fade-up delay-100 font-heading text-4xl font-extrabold tracking-tight sm:text-5xl lg:text-7xl max-w-4xl">
        The open source
        <span class="block" style="background: linear-gradient(135deg, oklch(0.80 0.12 280), oklch(0.68 0.19 280), oklch(0.65 0.20 310)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
          AI media studio
        </span>
      </h1>

      <!-- Subheading -->
      <p class="animate-fade-up delay-200 mt-6 max-w-2xl text-lg leading-relaxed text-[var(--color-muted)]">
        The AI media studio for creators, teams, and brands. Your keys, your infrastructure, your data.
      </p>

      <!-- Install methods -->
      <div class="animate-fade-up delay-300 mt-10 w-full max-w-2xl">
        <div class="rounded-2xl ring-1 ring-[var(--color-border)] bg-[var(--color-card)] overflow-hidden shadow-2xl shadow-[var(--color-primary)]/5">
          <!-- Tab bar -->
          <div class="flex items-center border-b border-[var(--color-border)]" id="install-tabs">
            {installMethods.map((method, i) => (
              <button
                data-tab={i}
                class:list={[
                  "install-tab px-5 py-3 text-xs font-medium transition-colors border-b-2 cursor-pointer",
                  i === 0
                    ? "text-[var(--color-primary)] border-[var(--color-primary)]"
                    : "text-[var(--color-muted)] border-transparent hover:text-[var(--color-foreground)]",
                ]}
              >
                {method.label}
              </button>
            ))}
            <div class="flex-1" />
            <button id="copy-btn" class="px-4 py-3 text-xs text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors cursor-pointer" title="Copy to clipboard">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
            </button>
          </div>
          <!-- Command panels -->
          <div class="p-4 sm:p-5 font-mono text-xs sm:text-sm leading-relaxed text-left overflow-x-auto">
            {installMethods.map((method, i) => (
              <div data-panel={i} class:list={["install-panel", i !== 0 && "hidden"]}>
                {method.commands.map((cmd, j) => {
                  const colors = ['var(--color-sky)', 'var(--color-primary)', 'var(--color-fuchsia)', 'var(--color-violet)'];
                  return (
                    <p class:list={[j > 0 && "mt-1"]}><span class="text-[var(--color-muted)]">$</span> <span style={`color: ${colors[j % colors.length]}`}>{cmd}</span></p>
                  );
                })}
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- CTAs -->
      <div class="animate-fade-up delay-400 mt-8 flex flex-col sm:flex-row items-center gap-4">
        <a href="https://github.com/opencauldron/opencauldron" target="_blank" rel="noopener"
          class="inline-flex h-12 items-center gap-2.5 rounded-xl px-7 text-sm font-semibold text-white transition-all hover:shadow-xl hover:shadow-[var(--color-primary)]/20 active:translate-y-px animate-shimmer"
          style="background: linear-gradient(135deg, oklch(0.58 0.22 280), oklch(0.65 0.20 300), oklch(0.68 0.19 280), oklch(0.60 0.22 260));">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          View on GitHub
        </a>
        <a href="/docs/introduction/"
          class="inline-flex h-12 items-center gap-2 rounded-xl px-7 text-sm font-medium text-[var(--color-foreground)] ring-1 ring-[var(--color-border)] hover:ring-[var(--color-primary)]/40 hover:bg-[var(--color-card)] transition-all">
          Read the Docs
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="relative z-10 mx-auto max-w-4xl px-4 sm:px-6 pb-16 sm:pb-20">
    <div class="animate-fade-up delay-500 grid grid-cols-2 sm:grid-cols-4 gap-4">
      <div class="text-center p-5 rounded-xl ring-1 ring-[var(--color-border)] bg-[var(--color-card)]">
        <p class="font-heading text-2xl font-bold text-[var(--color-foreground)]">10+</p>
        <p class="text-xs text-[var(--color-muted)] mt-1">AI Models</p>
      </div>
      <div class="text-center p-5 rounded-xl ring-1 ring-[var(--color-border)] bg-[var(--color-card)]">
        <p class="font-heading text-2xl font-bold text-[var(--color-foreground)]">100%</p>
        <p class="text-xs text-[var(--color-muted)] mt-1">Open Source</p>
      </div>
      <div class="text-center p-5 rounded-xl ring-1 ring-[var(--color-border)] bg-[var(--color-card)]">
        <p class="font-heading text-2xl font-bold text-[var(--color-foreground)]">MIT</p>
        <p class="text-xs text-[var(--color-muted)] mt-1">Licensed</p>
      </div>
      <div class="text-center p-5 rounded-xl ring-1 ring-[var(--color-border)] bg-[var(--color-card)]">
        <p class="font-heading text-2xl font-bold text-[var(--color-foreground)]">0</p>
        <p class="text-xs text-[var(--color-muted)] mt-1">Data Collected</p>
      </div>
    </div>
  </section>

  <!-- App Showcase -->
  <section id="app-showcase" class="relative z-10 mx-auto max-w-6xl px-4 sm:px-6 py-16 sm:py-24 lg:py-32 overflow-hidden">
    <!-- Section header -->
    <div class="text-center mb-14" data-showcase-header>
      <h2 class="font-heading text-3xl font-bold tracking-tight sm:text-4xl">
        See it in
        <span style="background: linear-gradient(135deg, oklch(0.76 0.13 280), oklch(0.65 0.20 300)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">action</span>
      </h2>
      <p class="mt-4 text-[var(--color-muted)] max-w-xl mx-auto">
        One interface for every AI model. Generate, manage, and track — all in one place.
      </p>
    </div>

    <!-- Browser mockup -->
    <div class="showcase-perspective" style="perspective: 1200px;">
      <div class="showcase-browser" data-showcase-browser>
        <!-- Browser chrome -->
        <div class="flex items-center gap-2 px-4 py-3 border-b border-[var(--color-border)] bg-[oklch(0.14_0.02_280)]">
          <div class="hidden sm:flex gap-1.5">
            <div class="w-3 h-3 rounded-full bg-[oklch(0.65_0.15_25)]"></div>
            <div class="w-3 h-3 rounded-full bg-[oklch(0.75_0.15_85)]"></div>
            <div class="w-3 h-3 rounded-full bg-[oklch(0.65_0.15_145)]"></div>
          </div>
          <div class="flex-1 sm:mx-3 rounded-md bg-[var(--color-background)] px-3 py-1.5 text-xs text-[var(--color-muted)] font-mono truncate">
            <span data-url-text>studio.yourdomain.com/generate</span>
          </div>
        </div>

        <!-- Step navigation (replaces old screen tabs) -->
        <div class="relative flex items-center border-b border-[var(--color-border)] bg-[oklch(0.13_0.02_280)]">
          <button data-walk-tab="0" class="showcase-tab active">Prompt</button>
          <button data-walk-tab="1" class="showcase-tab">Model</button>
          <button data-walk-tab="2" class="showcase-tab">Enhance</button>
          <button data-walk-tab="3" class="showcase-tab">Settings</button>
          <button data-walk-tab="4" class="showcase-tab">Generate</button>
          <div class="showcase-tab-indicator" data-tab-indicator></div>
        </div>

        <!-- Screen viewport -->
        <div class="relative overflow-hidden bg-[var(--color-background)]" style="aspect-ratio: 1/1;" id="showcase-viewport">
          <div class="h-full flex flex-col sm:flex-row">
            <!-- Left: Walkthrough steps -->
            <div class="flex-1 flex flex-col overflow-hidden">
              <!-- Walkthrough content area -->
              <div class="flex-1 relative">

                  <!-- Step 1: Full generate sidebar -->
                  <div data-walk-step="0" class="walk-step active absolute inset-0 p-4 sm:p-5 flex flex-col gap-2.5 overflow-y-auto">
                    <!-- Page header -->
                    <div class="flex items-center gap-2">
                      <div class="flex h-7 w-7 items-center justify-center rounded-lg bg-[var(--color-primary)]/10">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5"><path d="m21.64 3.64-1.28-1.28a1.21 1.21 0 0 0-1.72 0L2.36 18.64a1.21 1.21 0 0 0 0 1.72l1.28 1.28a1.2 1.2 0 0 0 1.72 0L21.64 5.36a1.2 1.2 0 0 0 0-1.72"/></svg>
                      </div>
                      <div>
                        <p class="text-xs font-semibold">Generate</p>
                        <p class="text-[9px] text-[var(--color-muted)]">Create images and videos with AI-powered generation.</p>
                      </div>
                    </div>
                    <!-- Media tabs -->
                    <div class="flex rounded-lg bg-[var(--color-card)] p-0.5">
                      <div class="flex-1 flex items-center justify-center gap-1.5 py-1.5 rounded-md bg-[var(--color-background)] text-[10px] font-medium">
                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="18" height="18" x="3" y="3" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
                        Image <span class="text-[var(--color-muted)]">5</span>
                      </div>
                      <div class="flex-1 flex items-center justify-center gap-1.5 py-1.5 text-[10px] text-[var(--color-muted)]">
                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m16 13 5.223 3.482a.5.5 0 0 0 .777-.416V7.87a.5.5 0 0 0-.752-.432L16 10.5"/><rect x="2" y="6" width="14" height="12" rx="2"/></svg>
                        Video <span>5</span>
                      </div>
                    </div>
                    <!-- Compact prompt with typing -->
                    <div class="rounded-xl ring-1 ring-[var(--color-primary)]/30 bg-[var(--color-card)] p-3">
                      <div class="text-[10px] sm:text-xs text-[var(--color-muted)]/80 leading-relaxed min-h-[3.5rem]">
                        <span data-typing-target>A glowing cauldron made of dark obsidian stone, bubbling with iridescent purple and teal liquid, ancient runes floating upward, mystical particles swirling in the air, dark fantasy atmosphere, volumetric lighting, cinematic composition</span>
