---
import Layout from "../layouts/Layout.astro";

const colors = [
  { name: "Background", var: "--color-background", value: "oklch(0.12 0.02 280)", desc: "Page & section backgrounds" },
  { name: "Foreground", var: "--color-foreground", value: "oklch(0.94 0.008 280)", desc: "Primary text color" },
  { name: "Card", var: "--color-card", value: "oklch(0.16 0.02 280)", desc: "Card & elevated surfaces" },
  { name: "Primary", var: "--color-primary", value: "oklch(0.68 0.19 280)", desc: "Interactive elements, links, emphasis" },
  { name: "Primary FG", var: "--color-primary-fg", value: "oklch(0.98 0.005 280)", desc: "Text on primary backgrounds" },
  { name: "Muted", var: "--color-muted", value: "oklch(0.58 0.025 280)", desc: "Secondary text, placeholders" },
  { name: "Border", var: "--color-border", value: "oklch(0.26 0.025 280)", desc: "Borders, dividers, outlines" },
  { name: "Violet", var: "--color-violet", value: "oklch(0.65 0.20 300)", desc: "Accent — violet range" },
  { name: "Fuchsia", var: "--color-fuchsia", value: "oklch(0.68 0.20 325)", desc: "Accent — warm pink" },
  { name: "Sky", var: "--color-sky", value: "oklch(0.72 0.14 240)", desc: "Accent — cool blue" },
  { name: "Teal", var: "--color-teal", value: "oklch(0.70 0.12 195)", desc: "Accent — green-blue" },
];

const gradients = [
  { name: "Heading", css: "linear-gradient(135deg, oklch(0.80 0.12 280), oklch(0.68 0.19 280), oklch(0.65 0.20 310))", usage: "Hero headlines" },
  { name: "Creative", css: "linear-gradient(135deg, oklch(0.68 0.20 325), oklch(0.65 0.20 300))", usage: "Gamification headlines" },
  { name: "CTA Button", css: "linear-gradient(135deg, oklch(0.58 0.22 280), oklch(0.65 0.20 300), oklch(0.68 0.19 280), oklch(0.60 0.22 260))", usage: "Primary action buttons" },
  { name: "Ambient Top", css: "radial-gradient(ellipse at 20% 0%, oklch(0.20 0.06 280 / 0.20) 0%, transparent 55%)", usage: "Body background layer" },
  { name: "Ambient Bottom", css: "radial-gradient(ellipse at 80% 100%, oklch(0.18 0.05 310 / 0.15) 0%, transparent 55%)", usage: "Body background layer" },
];

const typeSamples = [
  { tag: "h1", class: "text-4xl sm:text-5xl lg:text-7xl", weight: "font-extrabold", sample: "The open source" },
  { tag: "h2", class: "text-3xl sm:text-4xl", weight: "font-bold", sample: "Section heading" },
  { tag: "h3", class: "text-xl sm:text-2xl", weight: "font-bold", sample: "Card or subsection" },
  { tag: "h4", class: "text-lg", weight: "font-semibold", sample: "Feature title" },
  { tag: "p (body)", class: "text-base", weight: "font-normal", sample: "The AI creative studio for creators, teams, and brands." },
  { tag: "p (sm)", class: "text-sm", weight: "font-normal", sample: "Secondary body text and descriptions" },
  { tag: "caption", class: "text-xs", weight: "font-medium", sample: "LABELS, BADGES, AND CAPTIONS" },
];
---

<Layout title="Style Guide — OpenCauldron Design System">
  <!-- Nav (simplified) -->
  <nav class="sticky top-0 z-50 border-b border-[var(--color-border)] backdrop-blur-xl bg-[var(--color-background)]/80">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-4 sm:px-6 py-3 sm:py-4">
      <a href="/" class="flex items-center gap-2 sm:gap-3">
        <div class="flex h-8 w-8 sm:h-9 sm:w-9 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br from-[oklch(0.50_0.22_280)] to-[oklch(0.40_0.20_300)] shadow-lg shadow-[var(--color-primary)]/25">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="m21.64 3.64-1.28-1.28a1.21 1.21 0 0 0-1.72 0L2.36 18.64a1.21 1.21 0 0 0 0 1.72l1.28 1.28a1.2 1.2 0 0 0 1.72 0L21.64 5.36a1.2 1.2 0 0 0 0-1.72"/>
            <path d="m14 7 3 3"/><path d="M5 6v4"/><path d="M19 14v4"/><path d="M10 2v2"/><path d="M7 8H3"/><path d="M21 16h-4"/><path d="M11 3H9"/>
          </svg>
        </div>
        <span class="font-heading text-base sm:text-lg font-bold tracking-tight">OpenCauldron</span>
        <span class="rounded-full bg-[var(--color-primary)]/10 px-2 py-0.5 text-[10px] font-semibold text-[var(--color-primary)] ring-1 ring-[var(--color-primary)]/20">Style Guide</span>
      </a>
      <a href="/" class="text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors">&larr; Back to site</a>
    </div>
  </nav>

  <!-- Page header -->
  <section class="relative z-10 mx-auto max-w-5xl px-4 sm:px-6 pt-16 sm:pt-24 pb-12">
    <p class="text-xs font-semibold tracking-widest uppercase text-[var(--color-fuchsia)] mb-4">Design System</p>
    <h1 class="font-heading text-4xl sm:text-5xl font-extrabold tracking-tight">
      Style
      <span style="background: linear-gradient(135deg, oklch(0.80 0.12 280), oklch(0.68 0.19 280), oklch(0.65 0.20 310)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Guide</span>
    </h1>
    <p class="mt-4 text-[var(--color-muted)] max-w-2xl leading-relaxed text-balance">
      The visual language of OpenCauldron. Colors, typography, components, and patterns that make up the interface.
    </p>
    <!-- TOC -->
    <div class="mt-8 flex flex-wrap gap-2">
      {["Colors", "Gradients", "Typography", "Components", "Icons", "Animation"].map((s) => (
        <a href={`#${s.toLowerCase()}`} class="rounded-lg px-3 py-1.5 text-xs font-medium text-[var(--color-muted)] ring-1 ring-[var(--color-border)] hover:ring-[var(--color-primary)]/40 hover:text-[var(--color-foreground)] transition-all">
          {s}
        </a>
      ))}
    </div>
  </section>

  <!-- ─── COLORS ─── -->
  <section id="colors" class="relative z-10 mx-auto max-w-5xl px-4 sm:px-6 py-12 sm:py-16">
    <div class="flex items-center gap-3 mb-8">
      <div class="h-px flex-1 bg-[var(--color-border)]"></div>
      <h2 class="font-heading text-sm font-bold tracking-widest uppercase text-[var(--color-muted)]">Colors</h2>
      <div class="h-px flex-1 bg-[var(--color-border)]"></div>
    </div>

    <!-- Core palette -->
    <h3 class="font-heading text-lg font-bold mb-4">Core Palette</h3>
    <p class="text-sm text-[var(--color-muted)] mb-6 max-w-xl">
      Built on OKLCH for perceptually uniform color. All hues rotate around the 280 axis (purple) with accents branching toward blue (240), fuchsia (325), and teal (195).
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
      {colors.map((c) => (
        <div class="group rounded-xl ring-1 ring-[var(--color-border)] bg-[var(--color-card)] overflow-hidden hover:ring-[var(--color-primary)]/30 transition-all">
          <div class="h-16" style={`background: var(${c.var})`}></div>
          <div class="p-3">
            <div class="flex items-center justify-between">
              <p class="text-sm font-semibold">{c.name}</p>
              <code class="text-[10px] font-mono text-[var(--color-muted)] bg-[var(--color-background)] px-1.5 py-0.5 rounded">{c.var}</code>
            </div>
            <p class="text-xs text-[var(--color-muted)] mt-1">{c.desc}</p>
            <p class="text-[10px] font-mono text-[var(--color-muted)]/70 mt-1.5">{c.value}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Accent usage -->
    <h3 class="font-heading text-lg font-bold mt-12 mb-4">Accent Color Usage</h3>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      {[
        { name: "Primary", var: "--color-primary", usage: "Default interactive" },
        { name: "Violet", var: "--color-violet", usage: "Gradient stops" },
        { name: "Fuchsia", var: "--color-fuchsia", usage: "Badges, callouts" },
        { name: "Sky", var: "--color-sky", usage: "Code, highlights" },
      ].map((c) => (
        <div class="text-center p-5 rounded-xl ring-1 ring-[var(--color-border)] bg-[var(--color-card)]">
          <div class="mx-auto h-10 w-10 rounded-full mb-3" style={`background: var(${c.var})`}></div>
          <p class="text-sm font-semibold" style={`color: var(${c.var})`}>{c.name}</p>
          <p class="text-[10px] text-[var(--color-muted)] mt-0.5">{c.usage}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ─── GRADIENTS ─── -->
  <section id="gradients" class="relative z-10 mx-auto max-w-5xl px-4 sm:px-6 py-12 sm:py-16">
    <div class="flex items-center gap-3 mb-8">
      <div class="h-px flex-1 bg-[var(--color-border)]"></div>
      <h2 class="font-heading text-sm font-bold tracking-widest uppercase text-[var(--color-muted)]">Gradients</h2>
      <div class="h-px flex-1 bg-[var(--color-border)]"></div>
    </div>

    <div class="space-y-4">
      {gradients.map((g) => (
        <div class="rounded-xl ring-1 ring-[var(--color-border)] bg-[var(--color-card)] overflow-hidden">
          <div class="h-20 sm:h-24" style={`background: ${g.css}`}></div>
          <div class="p-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
            <div>
              <p class="text-sm font-semibold">{g.name}</p>
              <p class="text-xs text-[var(--color-muted)]">{g.usage}</p>
            </div>
            <code class="text-[10px] font-mono text-[var(--color-muted)] bg-[var(--color-background)] px-2 py-1 rounded break-all max-w-md">{g.css}</code>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ─── TYPOGRAPHY ─── -->
  <section id="typography" class="relative z-10 mx-auto max-w-5xl px-4 sm:px-6 py-12 sm:py-16">
    <div class="flex items-center gap-3 mb-8">
      <div class="h-px flex-1 bg-[var(--color-border)]"></div>
      <h2 class="font-heading text-sm font-bold tracking-widest uppercase text-[var(--color-muted)]">Typography</h2>
      <div class="h-px flex-1 bg-[var(--color-border)]"></div>
    </div>

    <!-- Font families -->
    <div class="grid sm:grid-cols-3 gap-4 mb-10">
      <div class="rounded-xl ring-1 ring-[var(--color-border)] bg-[var(--color-card)] p-5">
        <p class="text-xs font-semibold text-[var(--color-sky)] tracking-widest uppercase mb-3">Heading</p>
        <p class="font-heading text-2xl font-bold">Plus Jakarta Sans</p>
        <p class="text-xs text-[var(--color-muted)] mt-2 font-mono">--font-heading</p>
        <p class="text-xs text-[var(--color-muted)] mt-1">Weights: 600, 700, 800</p>
      </div>
      <div class="rounded-xl ring-1 ring-[var(--color-border)] bg-[var(--color-card)] p-5">
        <p class="text-xs font-semibold text-[var(--color-fuchsia)] tracking-widest uppercase mb-3">Body</p>
        <p class="text-2xl font-medium">Inter</p>
        <p class="text-xs text-[var(--color-muted)] mt-2 font-mono">--font-sans</p>
        <p class="text-xs text-[var(--color-muted)] mt-1">Weights: 400, 500, 600</p>
      </div>
      <div class="rounded-xl ring-1 ring-[var(--color-border)] bg-[var(--color-card)] p-5">
        <p class="text-xs font-semibold text-[var(--color-violet)] tracking-widest uppercase mb-3">Mono</p>
        <p class="font-mono text-2xl font-medium">Cascadia Code</p>
        <p class="text-xs text-[var(--color-muted)] mt-2 font-mono">--font-mono</p>
        <p class="text-xs text-[var(--color-muted)] mt-1">Code blocks, CLI</p>
      </div>
    </div>

    <!-- Type scale -->
    <h3 class="font-heading text-lg font-bold mb-6">Type Scale</h3>
    <div class="space-y-6">
      {typeSamples.map((t) => (
        <div class="flex flex-col sm:flex-row sm:items-baseline gap-2 sm:gap-6 pb-6 border-b border-[var(--color-border)] last:border-0">
          <div class="shrink-0 w-24">
            <code class="text-[10px] font-mono text-[var(--color-primary)]">&lt;{t.tag}&gt;</code>
            <p class="text-[10px] text-[var(--color-muted)] mt-0.5">{t.class}</p>
          </div>
          <p class:list={[t.tag.startsWith("h") ? "font-heading" : "", t.class.split(" ")[0], t.weight, "tracking-tight"]}>
            {t.sample}
          </p>
        </div>
      ))}
    </div>

    <!-- Gradient text -->
    <h3 class="font-heading text-lg font-bold mt-12 mb-4">Gradient Text</h3>
    <p class="text-sm text-[var(--color-muted)] mb-6">Headlines use gradient fills for emphasis. Apply via inline style with <code class="text-[10px] font-mono text-[var(--color-primary)] bg-[var(--color-card)] px-1.5 py-0.5 rounded">background-clip: text</code>.</p>
    <div class="space-y-4">
      <p class="font-heading text-3xl sm:text-4xl font-bold tracking-tight">
        The open source <span style="background: linear-gradient(135deg, oklch(0.80 0.12 280), oklch(0.68 0.19 280), oklch(0.65 0.20 310)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">AI creative studio</span>
      </p>
      <p class="font-heading text-3xl sm:text-4xl font-bold tracking-tight">
        Level up your <span style="background: linear-gradient(135deg, oklch(0.68 0.20 325), oklch(0.65 0.20 300)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">creative team</span>
      </p>
      <p class="font-heading text-3xl sm:text-4xl font-bold tracking-tight">
        See it in <span style="background: linear-gradient(135deg, oklch(0.76 0.13 280), oklch(0.65 0.20 300)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">action</span>
      </p>
    </div>
  </section>

  <!-- ─── COMPONENTS ─── -->
  <section id="components" class="relative z-10 mx-auto max-w-5xl px-4 sm:px-6 py-12 sm:py-16">
    <div class="flex items-center gap-3 mb-8">
      <div class="h-px flex-1 bg-[var(--color-border)]"></div>
      <h2 class="font-heading text-sm font-bold tracking-widest uppercase text-[var(--color-muted)]">Components</h2>
      <div class="h-px flex-1 bg-[var(--color-border)]"></div>
    </div>

    <!-- Badges -->
    <h3 class="font-heading text-lg font-bold mb-4">Badges</h3>
    <div class="flex flex-wrap gap-3 mb-10">
      <div class="inline-flex items-center gap-2 rounded-full bg-[var(--color-fuchsia)]/10 px-4 py-1.5 text-xs font-semibold text-[var(--color-fuchsia)] ring-1 ring-[var(--color-fuchsia)]/20">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m21.64 3.64-1.28-1.28a1.21 1.21 0 0 0-1.72 0L2.36 18.64a1.21 1.21 0 0 0 0 1.72l1.28 1.28a1.2 1.2 0 0 0 1.72 0L21.64 5.36a1.2 1.2 0 0 0 0-1.72"/>
          <path d="m14 7 3 3"/><path d="M5 6v4"/><path d="M19 14v4"/><path d="M10 2v2"/><path d="M7 8H3"/><path d="M21 16h-4"/><path d="M11 3H9"/>
        </svg>
        Hero callout badge
      </div>
      <div class="inline-flex items-center gap-2 rounded-full bg-[var(--color-fuchsia)]/10 px-4 py-1.5 text-xs font-semibold text-[var(--color-fuchsia)] ring-1 ring-[var(--color-fuchsia)]/20">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        Gamification built in
      </div>
      <span class="rounded-full bg-[var(--color-primary)]/10 px-2 py-0.5 text-[10px] font-semibold text-[var(--color-primary)] ring-1 ring-[var(--color-primary)]/20">v0.1.0</span>
      <span class="rounded-full bg-[var(--color-sky)]/10 px-2 py-0.5 text-[10px] font-semibold text-[var(--color-sky)] ring-1 ring-[var(--color-sky)]/20">New</span>
      <span class="rounded-full bg-[var(--color-teal)]/10 px-2 py-0.5 text-[10px] font-semibold text-[var(--color-teal)] ring-1 ring-[var(--color-teal)]/20">Beta</span>
    </div>

    <!-- Buttons -->
    <h3 class="font-heading text-lg font-bold mb-4">Buttons</h3>
    <div class="flex flex-wrap items-center gap-4 mb-10">
      <a class="inline-flex h-12 items-center gap-2.5 rounded-xl px-7 text-sm font-semibold text-white transition-all hover:shadow-xl hover:shadow-[var(--color-primary)]/20 active:translate-y-px cursor-pointer"
        style="background: linear-gradient(135deg, oklch(0.58 0.22 280), oklch(0.65 0.20 300), oklch(0.68 0.19 280), oklch(0.60 0.22 260));">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        Primary CTA
      </a>
      <a class="inline-flex h-12 items-center gap-2 rounded-xl px-7 text-sm font-medium text-[var(--color-foreground)] ring-1 ring-[var(--color-border)] hover:ring-[var(--color-primary)]/40 hover:bg-[var(--color-card)] transition-all cursor-pointer">
        Secondary CTA
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/></svg>
      </a>
      <a class="inline-flex h-9 items-center gap-2 rounded-lg bg-[var(--color-card)] px-4 text-sm font-medium text-[var(--color-foreground)] ring-1 ring-[var(--color-border)] hover:ring-[var(--color-primary)]/40 transition-all cursor-pointer">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        Nav button
      </a>
    </div>

    <!-- Cards -->
    <h3 class="font-heading text-lg font-bold mb-4">Cards</h3>
    <div class="grid sm:grid-cols-3 gap-4 mb-10">
      <!-- Stat card -->
      <div class="text-center p-5 rounded-xl ring-1 ring-[var(--color-border)] bg-[var(--color-card)]">
        <p class="font-heading text-2xl font-bold text-[var(--color-foreground)]">10+</p>
        <p class="text-xs text-[var(--color-muted)] mt-1">AI Models</p>
      </div>
      <!-- Feature card -->
      <div class="rounded-xl ring-1 ring-[var(--color-border)] bg-[var(--color-card)] p-5 hover:ring-[var(--color-primary)]/30 transition-all">
        <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-[var(--color-primary)]/10 mb-3">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
        </div>
        <h4 class="text-sm font-semibold mb-1">Feature Card</h4>
        <p class="text-xs text-[var(--color-muted)]">With icon container and description text.</p>
      </div>
      <!-- Tech card -->
      <div class="flex items-center gap-3 rounded-xl ring-1 ring-[var(--color-border)] bg-[var(--color-card)] p-4 hover:ring-[var(--color-primary)]/30 transition-all">
        <div class="h-10 w-10 rounded-lg bg-[var(--color-background)] flex items-center justify-center shrink-0">
          <span class="text-lg">N</span>
        </div>
        <div>
          <p class="text-sm font-semibold">Tech Stack Card</p>
          <p class="text-[10px] text-[var(--color-muted)]">With logo and category</p>
        </div>
      </div>
    </div>

    <!-- Code block -->
    <h3 class="font-heading text-lg font-bold mb-4">Code Block</h3>
    <div class="rounded-2xl ring-1 ring-[var(--color-border)] bg-[var(--color-card)] overflow-hidden shadow-2xl shadow-[var(--color-primary)]/5 max-w-2xl mb-10">
      <div class="flex items-center border-b border-[var(--color-border)]">
        <button class="px-5 py-3 text-xs font-medium text-[var(--color-primary)] border-b-2 border-[var(--color-primary)]">git</button>
        <button class="px-5 py-3 text-xs font-medium text-[var(--color-muted)] border-b-2 border-transparent">docker</button>
        <button class="px-5 py-3 text-xs font-medium text-[var(--color-muted)] border-b-2 border-transparent">npm</button>
      </div>
      <div class="p-4 sm:p-5 font-mono text-xs sm:text-sm leading-relaxed">
        <p><span class="text-[var(--color-muted)]">$</span> <span style="color: var(--color-sky)">git clone https://github.com/opencauldron/opencauldron</span></p>
        <p class="mt-1"><span class="text-[var(--color-muted)]">$</span> <span style="color: var(--color-primary)">cd opencauldron</span></p>
        <p class="mt-1"><span class="text-[var(--color-muted)]">$</span> <span style="color: var(--color-fuchsia)">bun install</span></p>
        <p class="mt-1"><span class="text-[var(--color-muted)]">$</span> <span style="color: var(--color-violet)">bun run dev</span></p>
      </div>
    </div>

    <!-- Rings & borders -->
    <h3 class="font-heading text-lg font-bold mb-4">Surface Treatments</h3>
    <div class="grid sm:grid-cols-3 gap-4 mb-10">
      <div class="rounded-xl ring-1 ring-[var(--color-border)] bg-[var(--color-card)] p-5">
        <p class="text-xs font-semibold mb-1">Default surface</p>
        <p class="text-[10px] text-[var(--color-muted)]">ring-1 ring-border bg-card</p>
      </div>
      <div class="rounded-xl ring-1 ring-[var(--color-primary)]/30 bg-[var(--color-card)] p-5">
        <p class="text-xs font-semibold mb-1">Active / hover</p>
        <p class="text-[10px] text-[var(--color-muted)]">ring-primary/30</p>
      </div>
      <div class="rounded-xl ring-1 ring-[var(--color-border)] bg-[var(--color-card)] p-5 shadow-2xl shadow-[var(--color-primary)]/5">
        <p class="text-xs font-semibold mb-1">Elevated</p>
        <p class="text-[10px] text-[var(--color-muted)]">shadow-2xl shadow-primary/5</p>
      </div>
    </div>

    <!-- Nav link -->
    <h3 class="font-heading text-lg font-bold mb-4">Nav Links</h3>
    <div class="flex items-center gap-5 mb-10">
      <a class="text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors cursor-pointer">Preview</a>
      <a class="text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors cursor-pointer">Features</a>
      <a class="text-sm text-[var(--color-foreground)] transition-colors cursor-pointer">Active</a>
      <a class="text-sm text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors cursor-pointer">Docs</a>
    </div>
  </section>

  <!-- ─── ICONS ─── -->
  <section id="icons" class="relative z-10 mx-auto max-w-5xl px-4 sm:px-6 py-12 sm:py-16">
    <div class="flex items-center gap-3 mb-8">
      <div class="h-px flex-1 bg-[var(--color-border)]"></div>
      <h2 class="font-heading text-sm font-bold tracking-widest uppercase text-[var(--color-muted)]">Icons</h2>
      <div class="h-px flex-1 bg-[var(--color-border)]"></div>
    </div>

    <p class="text-sm text-[var(--color-muted)] mb-6 max-w-xl">
      Inline SVGs based on Lucide conventions. Stroke-based, 24&times;24 viewBox, rendered at 12-20px. The magic wand is the brand icon.
    </p>

    <div class="grid grid-cols-3 sm:grid-cols-6 gap-3">
      {[
        { name: "Wand (brand)", svg: `<path d="m21.64 3.64-1.28-1.28a1.21 1.21 0 0 0-1.72 0L2.36 18.64a1.21 1.21 0 0 0 0 1.72l1.28 1.28a1.2 1.2 0 0 0 1.72 0L21.64 5.36a1.2 1.2 0 0 0 0-1.72"/><path d="m14 7 3 3"/><path d="M5 6v4"/><path d="M19 14v4"/><path d="M10 2v2"/><path d="M7 8H3"/><path d="M21 16h-4"/><path d="M11 3H9"/>`, color: "var(--color-fuchsia)" },
        { name: "Layers", svg: `<path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.84Z"/><path d="m22 12.5-8.58 3.91a2 2 0 0 1-1.66 0L2 12.5"/>`, color: "var(--color-primary)" },
        { name: "Key", svg: `<circle cx="7.5" cy="15.5" r="5.5"/><path d="m21 2-9.3 9.3"/><path d="m18 5 3-3"/>`, color: "var(--color-sky)" },
        { name: "Users", svg: `<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`, color: "var(--color-violet)" },
        { name: "Bolt", svg: `<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>`, color: "var(--color-fuchsia)" },
        { name: "Server", svg: `<rect width="20" height="8" x="2" y="2" rx="2" ry="2"/><rect width="20" height="8" x="2" y="14" rx="2" ry="2"/><line x1="6" x2="6.01" y1="6" y2="6"/><line x1="6" x2="6.01" y1="18" y2="18"/>`, color: "var(--color-teal)" },
      ].map((icon) => (
        <div class="flex flex-col items-center gap-2 p-4 rounded-xl ring-1 ring-[var(--color-border)] bg-[var(--color-card)]">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke={icon.color} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={icon.svg} />
          <p class="text-[10px] text-[var(--color-muted)] text-center">{icon.name}</p>
        </div>
      ))}
    </div>

    <!-- Icon container pattern -->
    <h3 class="font-heading text-lg font-bold mt-10 mb-4">Icon Containers</h3>
    <div class="flex flex-wrap items-center gap-4">
      <div class="flex h-9 w-9 items-center justify-center rounded-xl bg-gradient-to-br from-[oklch(0.50_0.22_280)] to-[oklch(0.40_0.20_300)] shadow-lg shadow-[var(--color-primary)]/25">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="m21.64 3.64-1.28-1.28a1.21 1.21 0 0 0-1.72 0L2.36 18.64a1.21 1.21 0 0 0 0 1.72l1.28 1.28a1.2 1.2 0 0 0 1.72 0L21.64 5.36a1.2 1.2 0 0 0 0-1.72"/>
          <path d="m14 7 3 3"/><path d="M5 6v4"/><path d="M19 14v4"/><path d="M10 2v2"/><path d="M7 8H3"/><path d="M21 16h-4"/><path d="M11 3H9"/>
        </svg>
      </div>
      <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-[var(--color-primary)]/10">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.84Z"/><path d="m22 12.5-8.58 3.91a2 2 0 0 1-1.66 0L2 12.5"/>
        </svg>
      </div>
      <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-[var(--color-fuchsia)]/10">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-fuchsia)" stroke-width="1.5"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
      </div>
      <div class="ml-4 text-xs text-[var(--color-muted)]">
        <p>Gradient: Nav logo (9&times;9, rounded-xl)</p>
        <p class="mt-0.5">Tinted: Feature icons (10&times;10, primary/10)</p>
        <p class="mt-0.5">Small: Inline badges (8&times;8)</p>
      </div>
    </div>
  </section>

  <!-- ─── ANIMATION ─── -->
  <section id="animation" class="relative z-10 mx-auto max-w-5xl px-4 sm:px-6 py-12 sm:py-16 pb-24 sm:pb-32">
    <div class="flex items-center gap-3 mb-8">
      <div class="h-px flex-1 bg-[var(--color-border)]"></div>
      <h2 class="font-heading text-sm font-bold tracking-widest uppercase text-[var(--color-muted)]">Animation</h2>
      <div class="h-px flex-1 bg-[var(--color-border)]"></div>
    </div>

    <div class="grid sm:grid-cols-2 gap-4">
      <!-- Fade up -->
      <div class="rounded-xl ring-1 ring-[var(--color-border)] bg-[var(--color-card)] p-5">
        <p class="text-sm font-semibold mb-1">fade-up</p>
        <p class="text-xs text-[var(--color-muted)] mb-3">Primary entrance animation. 0.7s cubic-bezier(0.16, 1, 0.3, 1). Stagger with delay-100 through delay-700.</p>
        <code class="text-[10px] font-mono text-[var(--color-sky)] bg-[var(--color-background)] px-2 py-1 rounded">.animate-fade-up .delay-200</code>
      </div>
      <!-- Shimmer -->
      <div class="rounded-xl ring-1 ring-[var(--color-border)] bg-[var(--color-card)] p-5">
        <p class="text-sm font-semibold mb-1">shimmer</p>
        <p class="text-xs text-[var(--color-muted)] mb-3">Gradient position cycle. 3s ease-in-out infinite. Used on primary CTA button.</p>
        <code class="text-[10px] font-mono text-[var(--color-fuchsia)] bg-[var(--color-background)] px-2 py-1 rounded">.animate-shimmer</code>
      </div>
      <!-- Float -->
      <div class="rounded-xl ring-1 ring-[var(--color-border)] bg-[var(--color-card)] p-5">
        <p class="text-sm font-semibold mb-1">float</p>
        <p class="text-xs text-[var(--color-muted)] mb-3">Gentle vertical bob. 4s ease-in-out infinite. Used on showcase browser mockup.</p>
        <code class="text-[10px] font-mono text-[var(--color-violet)] bg-[var(--color-background)] px-2 py-1 rounded">.animate-float</code>
      </div>
      <!-- Sparkle pulse -->
      <div class="rounded-xl ring-1 ring-[var(--color-border)] bg-[var(--color-card)] p-5">
        <p class="text-sm font-semibold mb-1">sparkle-pulse</p>
        <p class="text-xs text-[var(--color-muted)] mb-3">Ambient particle effect. Scales 0.8&rarr;1.2 and fades. Used on background sparkle particles.</p>
        <code class="text-[10px] font-mono text-[var(--color-primary)] bg-[var(--color-background)] px-2 py-1 rounded">sparkle-pulse ${`{3+n}`}s</code>
      </div>
    </div>

    <!-- Delay tokens -->
    <h3 class="font-heading text-lg font-bold mt-10 mb-4">Stagger Delays</h3>
    <div class="flex flex-wrap gap-2">
      {["100", "200", "300", "400", "500", "700"].map((d) => (
        <div class="flex items-center gap-2 rounded-lg bg-[var(--color-card)] ring-1 ring-[var(--color-border)] px-3 py-2">
          <div class="h-3 rounded-full bg-[var(--color-primary)]" style={`width: ${parseInt(d) / 10}px; opacity: ${0.4 + parseInt(d) / 1000}`}></div>
          <code class="text-[10px] font-mono text-[var(--color-muted)]">.delay-{d}</code>
          <span class="text-[10px] text-[var(--color-muted)]">{parseInt(d) / 1000}s</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Footer -->
  <footer class="relative z-10 border-t border-[var(--color-border)] py-8">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 flex items-center justify-between">
      <p class="text-xs text-[var(--color-muted)]">OpenCauldron Design System</p>
      <a href="/" class="text-xs text-[var(--color-muted)] hover:text-[var(--color-foreground)] transition-colors">&larr; Back to site</a>
    </div>
  </footer>
</Layout>
